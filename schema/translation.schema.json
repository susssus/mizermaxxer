{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "translation.schema.json",
  "title": "Translation",
  "type": "object",
  "required": ["id", "article_id", "review_status", "license"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "article_id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "publication": { "type": "string" },
    "issue_number": { "type": ["string", "null"] },
    "publication_date": {
      "type": ["string", "null"]
    },
    "page_count": { "type": ["integer", "null"] },
    "page_range": {
      "type": ["string", "null"],
      "description": "Magazine page number or range (e.g. 58–61) when distinct from translated page blocks."
    },
    "title_ja": { "type": ["string", "null"] },
    "title_en": { "type": ["string", "null"] },
    "subtitle": { "type": ["string", "null"] },
    "writer_ja": { "type": ["string", "null"] },
    "writer_en": { "type": ["string", "null"] },
    "writers_ja": { "type": ["string", "null"] },
    "writers_en": { "type": ["string", "null"] },
    "photographer_ja": { "type": ["string", "null"] },
    "photographer_en": { "type": ["string", "null"] },
    "translator": { "type": "string" },
    "translation_date": { "type": ["string", "null"] },
    "review_status": { "$ref": "vocabularies.json#/$defs/translation_review_status" },
    "license": {
      "type": "string",
      "const": "CC-BY-NC-4.0",
      "description": "SPDX-style license for the English translation text contributed by this project."
    },
    "license_notes": { "type": "string" },
    "scan_paths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source_scan_gallery": { "type": ["string", "null"] },
    "intro": { "$ref": "#/$defs/triLingualBlock" },
    "credits": { "$ref": "#/$defs/triLingualBlock" },
    "sidebar": { "$ref": "#/$defs/triLingualBlock" },
    "photo_spread_note": { "$ref": "#/$defs/triLingualBlock" },
    "footer": { "$ref": "#/$defs/triLingualBlock" },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["page"],
        "properties": {
          "page": { "type": "integer", "minimum": 1 },
          "section": { "type": ["string", "null"] },
          "content_type": { "type": ["string", "null"] },
          "ja": { "type": ["string", "null"] },
          "romaji": { "type": ["string", "null"] },
          "en": { "type": ["string", "null"] }
        },
        "additionalProperties": true
      }
    },
    "dialogue": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "speaker": { "type": "string" },
          "ja": { "type": ["string", "null"] },
          "romaji": { "type": ["string", "null"] },
          "en": { "type": ["string", "null"] }
        },
        "additionalProperties": true
      }
    },
    "content": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": ["string", "null"] },
          "ja": { "type": ["string", "null"] },
          "romaji": { "type": ["string", "null"] },
          "en": { "type": ["string", "null"] }
        },
        "additionalProperties": true
      }
    },
    "tour_dates": {
      "type": "array",
      "items": { "type": "object" }
    }
  },
  "anyOf": [
    { "required": ["dialogue"], "properties": { "dialogue": { "type": "array", "minItems": 1 } } },
    {
      "required": ["pages"],
      "properties": { "pages": { "type": "array", "minItems": 1 } }
    },
    { "required": ["content"], "properties": { "content": { "type": "array", "minItems": 1 } } }
  ],
  "$defs": {
    "triLingualBlock": {
      "type": "object",
      "properties": {
        "ja": { "type": ["string", "null"] },
        "romaji": { "type": ["string", "null"] },
        "en": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
