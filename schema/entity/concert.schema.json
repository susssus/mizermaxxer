{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "concert.schema.json",
  "title": "ConcertEntity",
  "allOf": [
    { "$ref": "entity.schema.json" },
    {
      "type": "object",
      "required": ["title", "date", "date_precision"],
      "properties": {
        "type": { "const": "concert" },
        "id": { "pattern": "^concert_[a-z0-9_]+$" },
        "title": { "$ref": "title.schema.json" },
        "date": { "type": "string", "pattern": "^[0-9]{4}(-[0-9]{2}(-[0-9]{2})?)?$" },
        "date_precision": { "$ref": "vocabularies.json#/$defs/date_precision" },
        "venue": { "type": ["string", "null"], "pattern": "^venue_[a-z0-9_]+$" },
        "concert_type": {
          "enum": ["live", "oneman", "festival", "event", "secret", "tv", "unknown"]
        },
        "setlist": {
          "type": "array",
          "items": { "type": "string", "pattern": "^song_[a-z0-9_]+$" }
        },
        "members_present": {
          "type": "array",
          "items": { "type": "string", "pattern": "^person_[a-z0-9_]+$" }
        },
        "performances": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["url", "platform"],
            "properties": {
              "url": { "type": "string" },
              "platform": {
                "enum": ["youtube", "niconico", "bilibili", "archive_org", "vimeo", "other"]
              },
              "quality": {
                "enum": ["official", "tv_broadcast", "pro_shot", "audience", "low", "unknown", null]
              },
              "title": { "type": ["string", "null"] },
              "notes": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "verification_status": { "$ref": "vocabularies.json#/$defs/verification_status" },
        "legacy_v1_slug": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}-[a-z0-9-]+$",
          "description": "v1 catalog concert id (data/concerts/<slug>.yaml) for crosswalk to /gigs pages."
        }
      }
    }
  ]
}
