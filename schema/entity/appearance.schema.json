{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "appearance.schema.json",
  "title": "AppearanceEntity",
  "allOf": [
    { "$ref": "entity.schema.json" },
    {
      "type": "object",
      "required": ["title", "date", "date_precision", "appearance_type", "format"],
      "properties": {
        "type": { "const": "appearance" },
        "id": { "pattern": "^appearance_[a-z0-9_]+$" },
        "title": { "$ref": "title.schema.json" },
        "appearance_type": {
          "enum": ["tv", "radio", "variety", "cm", "web", "other"]
        },
        "format": {
          "enum": ["performance", "interview", "talk", "cm", "mixed", "unknown"]
        },
        "date": { "type": "string", "pattern": "^[0-9]{4}(-[0-9]{2}(-[0-9]{2})?)?$" },
        "date_precision": { "$ref": "vocabularies.json#/$defs/date_precision" },
        "broadcast": {
          "type": ["object", "null"],
          "properties": {
            "network": { "type": ["string", "null"], "pattern": "^org_[a-z0-9_]+$" },
            "program": { "type": ["string", "null"] },
            "channel": { "type": ["string", "null"] }
          },
          "additionalProperties": false
        },
        "venue": { "type": ["string", "null"], "pattern": "^venue_[a-z0-9_]+$" },
        "members_present": {
          "type": "array",
          "items": { "type": "string", "pattern": "^person_[a-z0-9_]+$" }
        },
        "songs_performed": {
          "type": "array",
          "items": { "type": "string", "pattern": "^song_[a-z0-9_]+$" }
        },
        "performances": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["url", "platform"],
            "properties": {
              "url": { "type": "string" },
              "platform": {
                "enum": ["youtube", "niconico", "bilibili", "archive_org", "vimeo", "other"]
              },
              "quality": {
                "enum": ["official", "tv_broadcast", "pro_shot", "audience", "low", "unknown", null]
              },
              "title": { "type": ["string", "null"] },
              "notes": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "verification_status": { "$ref": "vocabularies.json#/$defs/verification_status" }
      }
    }
  ]
}
