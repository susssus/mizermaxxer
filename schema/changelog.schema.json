{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "changelog.schema.json",
  "title": "ChangelogEntry",
  "type": "object",
  "required": ["date", "action", "source", "notes"],
  "properties": {
    "date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "action": {
      "enum": ["created", "updated", "verified", "status_change", "research_note", "augmented"]
    },
    "source": { "type": "string" },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
