{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "article.schema.json",
  "title": "Article",
  "type": "object",
  "required": ["id", "type"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "title_ja": { "type": ["string", "null"] },
    "title_en": { "type": ["string", "null"] },
    "type": { "$ref": "vocabularies.json#/$defs/article_type" },
    "content_nature": { "$ref": "vocabularies.json#/$defs/content_nature" },
    "promotional_subtype": { "$ref": "vocabularies.json#/$defs/promotional_subtype" },
    "promotional_carrier": { "$ref": "vocabularies.json#/$defs/promotional_carrier" },
    "vkgy_roles": {
      "type": "array",
      "items": { "$ref": "vocabularies.json#/$defs/vkgy_role" }
    },
    "pages": { "type": ["string", "null"] },
    "members": {
      "type": "array",
      "items": { "$ref": "vocabularies.json#/$defs/member_slug" }
    },
    "photographer": { "type": ["string", "null"] },
    "writer": { "type": ["string", "null"] },
    "cover": { "type": "boolean" },
    "poster": { "type": "boolean" },
    "foldout": { "type": "boolean" },
    "scan": {
      "type": "object",
      "required": ["available"],
      "properties": {
        "available": { "type": "boolean" },
        "quality": {
          "oneOf": [
            { "$ref": "vocabularies.json#/$defs/scan_quality" },
            { "type": "null" }
          ]
        },
        "url": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "translation": {
      "type": "object",
      "required": ["available"],
      "properties": {
        "available": { "type": "boolean" },
        "url": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "purchase_links": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["url"],
        "properties": {
          "url": { "type": "string" },
          "platform": { "type": ["string", "null"] },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
