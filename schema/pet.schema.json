{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pet.schema.json",
  "title": "Pet",
  "type": "object",
  "required": [
    "id",
    "name_en",
    "species",
    "owner",
    "relationship",
    "verification_status",
    "summary",
    "changelog"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "name_en": { "type": "string" },
    "name_ja": { "type": ["string", "null"] },
    "species": {
      "type": "string",
      "enum": ["cat", "dog", "ferret", "hamster", "turtle", "frog", "other"]
    },
    "breed": { "type": ["string", "null"] },
    "sex": {
      "type": ["string", "null"],
      "enum": ["male", "female", "unknown", null]
    },
    "owner": { "$ref": "vocabularies.json#/$defs/member_slug" },
    "relationship": {
      "type": "string",
      "enum": ["owned_by", "childhood_family", "set_companion"]
    },
    "years_noted": { "type": ["string", "null"] },
    "status": {
      "type": ["string", "null"],
      "enum": ["living", "deceased", "unknown", null]
    },
    "died": { "type": ["string", "null"] },
    "portrait_image": { "type": ["string", "null"] },
    "gallery_images": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["src"],
        "properties": {
          "src": { "type": "string" },
          "caption": { "type": ["string", "null"] },
          "source": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    },
    "summary": { "type": "string" },
    "notes": { "type": ["string", "null"] },
    "translation_ids": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "source_urls": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "verification_status": { "$ref": "vocabularies.json#/$defs/verification_status" },
    "changelog": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "changelog.schema.json" }
    }
  },
  "additionalProperties": false
}
