{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "issue.schema.json",
  "title": "Issue",
  "type": "object",
  "required": [
    "id",
    "publication",
    "publication_date",
    "date_precision",
    "verification_status",
    "articles",
    "changelog"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "publication": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "issue_number": { "type": ["string", "null"] },
    "volume": { "type": ["string", "null"] },
    "publication_date": {
      "type": "string",
      "pattern": "^[0-9]{4}(-[0-9]{2}(-[0-9]{2})?)?$"
    },
    "date_precision": { "enum": ["year", "month", "day"] },
    "verification_status": {
      "enum": [
        "verified",
        "possible",
        "mention_only",
        "needs_verification",
        "disputed"
      ]
    },
    "source_notes": { "type": "string" },
    "research_targets": {
      "type": "array",
      "items": { "type": "string" }
    },
    "articles": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "article.schema.json" }
    },
    "changelog": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["date", "action", "source", "notes"],
        "properties": {
          "date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
          "action": {
            "enum": [
              "created",
              "updated",
              "verified",
              "status_change",
              "research_note"
            ]
          },
          "source": { "type": "string" },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
