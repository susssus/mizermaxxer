{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "issue.schema.json",
  "title": "Issue",
  "type": "object",
  "required": [
    "id",
    "publication",
    "publication_date",
    "date_precision",
    "verification_status",
    "articles",
    "changelog"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "publication": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "issue_number": { "type": ["string", "null"] },
    "volume": { "type": ["string", "null"] },
    "publication_date": {
      "type": "string",
      "pattern": "^[0-9]{4}(-[0-9]{2}(-[0-9]{2})?)?$"
    },
    "date_precision": { "$ref": "vocabularies.json#/$defs/date_precision" },
    "verification_status": { "$ref": "vocabularies.json#/$defs/verification_status" },
    "source_notes": { "type": "string" },
    "research_targets": {
      "type": "array",
      "items": { "type": "string" }
    },
    "articles": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "article.schema.json" }
    },
    "changelog": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "changelog.schema.json" }
    }
  },
  "additionalProperties": false
}
