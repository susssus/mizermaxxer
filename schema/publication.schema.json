{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "publication.schema.json",
  "title": "Publication",
  "type": "object",
  "required": ["slug", "name_ja", "name_en", "priority", "status"],
  "properties": {
    "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "name_ja": { "type": "string", "minLength": 1 },
    "name_en": { "type": "string", "minLength": 1 },
    "publisher": { "type": ["string", "null"] },
    "issn": { "type": ["string", "null"] },
    "years_active_start": { "type": ["integer", "null"], "minimum": 1980, "maximum": 2010 },
    "years_active_end": { "type": ["integer", "null"], "minimum": 1980, "maximum": 2010 },
    "priority": { "type": "integer", "minimum": 1, "maximum": 99 },
    "status": { "enum": ["verified", "needs_confirmation"] },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
