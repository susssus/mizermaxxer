{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "single.schema.json",
  "title": "Single",
  "type": "object",
  "required": ["id", "title_ja", "title_en", "release_date", "date_precision", "verification_status", "changelog"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "title_ja": { "type": "string" },
    "title_en": { "type": "string" },
    "release_date": { "type": "string", "pattern": "^[0-9]{4}(-[0-9]{2}(-[0-9]{2})?)?$" },
    "date_precision": { "$ref": "vocabularies.json#/$defs/date_precision" },
    "label": { "type": ["string", "null"] },
    "catalog_number": { "type": ["string", "null"] },
    "format": {
      "enum": ["cd", "vinyl", "cassette", "other", null]
    },
    "a_side": { "type": ["string", "null"] },
    "b_side": { "type": ["string", "null"] },
    "coupling_tracks": { "type": "array", "items": { "type": "string" } },
    "cover_image": { "type": ["string", "null"] },
    "verification_status": { "$ref": "vocabularies.json#/$defs/verification_status" },
    "notes": { "type": "string" },
    "changelog": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "changelog.schema.json" }
    }
  },
  "additionalProperties": false
}
