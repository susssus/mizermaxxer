---
import Base from "../../layouts/Base.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import PerformanceEmbed from "../../components/PerformanceEmbed.astro";
import NotFound from "../../components/NotFound.astro";
import TriggerWarning from "../../components/TriggerWarning.astro";
import archive from "../../data/archive.json";
import { concertEntityHref, personEntityHref, songEntityHref, venueEntityHref } from "../../lib/entities.ts";

export function getStaticPaths() {
  return archive.concerts.map((concert) => ({ params: { id: concert.id } }));
}

const { id } = Astro.params;
const concert = archive.concerts.find((entry) => entry.id === id);
const songMap = new Map(archive.songs.map((song) => [song.id, song]));

const embeddablePlatforms = new Set(["youtube", "archive_org", "niconico", "vimeo"]);
const embeddablePerformances =
  concert?.performances.filter((p) => embeddablePlatforms.has(p.platform)) ?? [];
const linkOnlyPerformances =
  concert?.performances.filter((p) => !embeddablePlatforms.has(p.platform)) ?? [];

const gigTitle = concert?.event_name_en ?? concert?.event_name_ja ?? concert?.id ?? "Concert";
const gigDescription = concert
  ? `Malice Mizer live on ${concert.date} at ${concert.venue_detail?.name_en ?? concert.venue ?? "unknown venue"}. Setlist, lineup, and performance links.`
  : undefined;
const venueEntity = concert?.venue ? venueEntityHref(concert.venue) : null;
const concertEntity = concert ? concertEntityHref(concert.id) : null;
---

{concert ? (
  <Base title={gigTitle} description={gigDescription} type="article">
    <Breadcrumbs
      items={[
        { label: "Gigs", href: "/gigs" },
        { label: gigTitle },
      ]}
    />
    {concertEntity && (
      <p class="muted entity-link">
        <a href={concertEntity}>View in entity graph →</a>
      </p>
    )}

    <section class="detail-grid">
      <div class="card">
        <h1>{concert.event_name_en ?? concert.event_name_ja ?? "Untitled event"}</h1>
        {concert.event_name_ja && concert.event_name_en && <p class="muted">{concert.event_name_ja}</p>}
        <p><strong>Date:</strong> {concert.date} ({concert.date_precision})</p>
        <p><strong>Type:</strong> {concert.type}</p>
        <p><strong>Venue:</strong>{" "}
          {venueEntity ? (
            <a href={venueEntity}>{concert.venue_detail?.name_en ?? concert.venue}</a>
          ) : (
            concert.venue_detail?.name_en ?? concert.venue ?? "Unknown"
          )}
        </p>
        <p><strong>Members:</strong>{" "}
          {concert.members_present.length ? (
            concert.members_present.map((member, index) => {
              const href = personEntityHref(member);
              return (
                <>
                  {index > 0 ? ", " : ""}
                  {href ? <a href={href}>{member}</a> : member}
                </>
              );
            })
          ) : (
            "—"
          )}
        </p>
        <p><strong>Status:</strong> <span class={`badge ${concert.verification_status}`}>{concert.verification_status.replaceAll("_", " ")}</span></p>
        {concert.source_notes && <p class="muted">{concert.source_notes}</p>}
      </div>

      <div class="card">
        <h2>Setlist</h2>
        {concert.setlist.length ? (
          <ol>
            {concert.setlist.map((songId) => {
              const song = songMap.get(songId);
              const href = songEntityHref(songId);
              return (
                <li>{href ? <a href={href}>{song?.title_en ?? songId}</a> : song?.title_en ?? songId}</li>
              );
            })}
          </ol>
        ) : (
          <p class="muted">Setlist not yet catalogued.</p>
        )}
      </div>
    </section>

    {embeddablePerformances.length > 0 && (
      <section class="card" style="margin-top: 1rem;">
        <h2>Footage</h2>
        {embeddablePerformances.map((performance) => (
          <PerformanceEmbed performance={performance} />
        ))}
      </section>
    )}

    <section class="card" style="margin-top: 1rem;">
      <h2>Performance links</h2>
      {concert.performances.length ? (
        linkOnlyPerformances.length > 0 ? (
          <ul>
            {linkOnlyPerformances.map((performance) => (
              <li>
                <a href={performance.url} target="_blank" rel="noopener noreferrer">
                  {performance.title ?? performance.platform}
                </a>
                {performance.trigger_warnings?.length ? (
                  <> <TriggerWarning warnings={performance.trigger_warnings} /></>
                ) : null}
                {performance.quality && <span class="muted"> ({performance.quality})</span>}
                {performance.notes && <p class="muted">{performance.notes}</p>}
              </li>
            ))}
          </ul>
        ) : embeddablePerformances.length === 0 ? (
          <p class="muted">No performance links yet.</p>
        ) : (
          <p class="muted">Embedded above — open source links from the video captions.</p>
        )
      ) : (
        <p class="muted">No performance links yet.</p>
      )}
    </section>
  </Base>
) : (
  <NotFound
    title="Concert not found"
    message="No gig matches that ID."
    backHref="/gigs"
    backLabel="← Back to gigs"
  />
)}
