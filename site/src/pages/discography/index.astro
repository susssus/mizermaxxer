---
import ImageSourceNote from "../../components/ImageSourceNote.astro";
import Base from "../../layouts/Base.astro";
import ReleaseRow from "../../components/ReleaseRow.astro";
import StatCard from "../../components/StatCard.astro";
import archive from "../../data/archive.json";

const songMap = new Map(archive.songs.map((song) => [song.id, song]));

function coverSrc(path?: string | null) {
  if (!path) return null;
  return path.startsWith("/") ? path : `/${path}`;
}

const studioTypes = new Set(["album", "ep"]);
const videoTypes = new Set(["vhs", "dvd", "live_album"]);
const compTypes = new Set(["compilation", "box_set"]);

const studioAlbums = archive.albums.filter((a) => studioTypes.has(a.type));
const compilations = archive.albums.filter((a) => compTypes.has(a.type));
const videoReleases = archive.albums.filter((a) => videoTypes.has(a.type));
const demosMisc = archive.albums.filter(
  (a) => a.type === "demo" || (!studioTypes.has(a.type) && !compTypes.has(a.type) && !videoTypes.has(a.type))
);
---

<Base
  title="Discography"
  description="Malice Mizer complete discography — studio albums, singles, compilations, and video releases from Memoire to Gardenia, with track listings and cover art (1992–2001)."
>
  <h1 class="page-heading">Discography</h1>
  <p class="muted page-intro">
    Browse releases in the <a href="/browse?type=song">entity graph</a> for linked songs and relationships.
  </p>
  <section class="stats">
    <StatCard value={studioAlbums.length} label="Studio albums" preset="studio" />
    <StatCard value={archive.stats.single_count} label="Singles" preset="singles" />
    <StatCard value={compilations.length} label="Compilations" preset="compilations" />
    <StatCard value={videoReleases.length} label="Video releases" preset="video" />
    <StatCard value={demosMisc.length} label="Demos & misc" preset="demos" />
    <StatCard value={archive.stats.song_count} label="Songs" href="/browse?type=song" />
  </section>

  <div id="discography-list">
    <section class="card" data-discography-section="studio">
      <h2>Studio albums & EP</h2>
      <table>
        <thead>
          <tr>
            <th></th><th>Date</th><th>Status</th><th>Title</th><th>Type</th><th>Label</th><th>Tracks</th>
          </tr>
        </thead>
        <tbody>{studioAlbums.map((album) => <ReleaseRow album={album} />)}</tbody>
      </table>
    </section>

    <section class="card" style="margin-top: 1rem;" data-discography-section="compilations">
      <h2>Compilations & box sets</h2>
      <table>
        <thead>
          <tr>
            <th></th><th>Date</th><th>Status</th><th>Title</th><th>Type</th><th>Label</th><th>Tracks</th>
          </tr>
        </thead>
        <tbody>{compilations.map((album) => <ReleaseRow album={album} />)}</tbody>
      </table>
    </section>

    <section class="card" style="margin-top: 1rem;" data-discography-section="video">
      <h2>Video releases (VHS / DVD / Blu-ray)</h2>
      <table>
        <thead>
          <tr>
            <th></th><th>Date</th><th>Status</th><th>Title</th><th>Type</th><th>Label</th><th>Tracks</th>
          </tr>
        </thead>
        <tbody>{videoReleases.map((album) => <ReleaseRow album={album} />)}</tbody>
      </table>
    </section>

    <section class="card" style="margin-top: 1rem;" data-discography-section="demos">
      <h2>Early demos & miscellaneous</h2>
      <table>
        <thead>
          <tr>
            <th></th><th>Date</th><th>Status</th><th>Title</th><th>Type</th><th>Label</th><th>Tracks</th>
          </tr>
        </thead>
        <tbody>{demosMisc.map((album) => <ReleaseRow album={album} />)}</tbody>
      </table>
    </section>

    <section class="card" style="margin-top: 1rem;" data-discography-section="singles">
      <h2>Singles</h2>
      <table>
        <thead>
          <tr>
            <th></th>
            <th>Date</th>
            <th>Status</th>
            <th>Title</th>
            <th>A-side</th>
            <th>B-side</th>
          </tr>
        </thead>
        <tbody>
          {archive.singles.map((single) => (
            <tr>
              <td class="cover-cell">
                {single.cover_image ? (
                  <figure class="cover-thumb-wrap">
                    <img class="cover-thumb" src={coverSrc(single.cover_image)!} alt="" loading="lazy" />
                    <ImageSourceNote src={single.cover_image} compact />
                  </figure>
                ) : (
                  "—"
                )}
              </td>
              <td>{single.release_date}</td>
              <td><span class={`badge ${single.verification_status}`}>{single.verification_status.replaceAll("_", " ")}</span></td>
              <td>
                <a href={`/discography/${single.id}`}>{single.title_en}</a>
                {single.title_ja && single.title_ja !== single.title_en && (
                  <><br /><span class="muted">{single.title_ja}</span></>
                )}
              </td>
              <td>{single.a_side ? songMap.get(single.a_side)?.title_en ?? single.a_side : "—"}</td>
              <td>{single.b_side ? songMap.get(single.b_side)?.title_en ?? single.b_side : "—"}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>
  </div>
</Base>

<script>
  const sections = Array.from(document.querySelectorAll("[data-discography-section]"));
  const buttons = Array.from(document.querySelectorAll("[data-stat-preset]"));

  function applyDiscographyPreset(preset: string) {
    sections.forEach((section) => {
      const key = (section as HTMLElement).dataset.discographySection ?? "";
      const visible = preset === "all" || key === preset;
      (section as HTMLElement).style.display = visible ? "" : "none";
    });

    buttons.forEach((button) => {
      button.classList.toggle(
        "stat--active",
        preset !== "all" && button.getAttribute("data-stat-preset") === preset
      );
    });

    document.getElementById("discography-list")?.scrollIntoView({ behavior: "smooth", block: "start" });
  }

  buttons.forEach((button) => {
    button.addEventListener("click", () => {
      const preset = button.getAttribute("data-stat-preset") ?? "all";
      const isActive = button.classList.contains("stat--active");
      applyDiscographyPreset(isActive ? "all" : preset);
    });
  });
</script>
