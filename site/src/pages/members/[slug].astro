---
import PersonProfile from "../../components/PersonProfile.astro";
import Base from "../../layouts/Base.astro";
import archive from "../../data/archive.json";

type PersonProfile = {
  id: string;
  name?: { romanized?: string; original?: string };
  era?: string | null;
  [key: string]: unknown;
};

const profiles = (archive.people_profiles ?? []) as PersonProfile[];

export function getStaticPaths() {
  const items = (archive.people_profiles ?? []) as PersonProfile[];
  return items.map((profile) => ({
    params: { slug: profile.id.replace(/^person_/, "") },
  }));
}

const { slug } = Astro.params;
const profile = profiles.find((p) => p.id === `person_${slug}` || p.id === slug);

const eraLabels: Record<string, string> = {
  tetsu: "Tetsu era",
  gackt: "Gackt era",
  klaha: "Klaha era",
  mana: "Gackt era",
  kozi: "Gackt era",
  yuki: "Gackt era",
  kami: "Gackt era",
};

const title = profile?.name?.romanized ?? profile?.name?.original ?? slug;
const entityId = profile?.id ?? `person_${slug}`;
---

{profile ? (
  <Base title={`${title} — Malice Mizer Research Archive`}>
    <a class="back" href="/">← Back to bibliography</a>
    <a class="back" href={`/entity/${entityId}`} style="margin-left: 1rem;">Entity graph →</a>

    <PersonProfile
      entity={{
        ...profile,
        era: eraLabels[slug ?? ""] ?? profile.era ?? null,
      }}
      title={title}
      typeLabel="Member"
      typeColor="purple"
    />
  </Base>
) : (
  <Base title="Member not found">
    <p>Member profile not found.</p>
    <a href="/">← Back</a>
  </Base>
)}
