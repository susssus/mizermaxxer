---
import PersonProfile from "../../components/PersonProfile.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Base from "../../layouts/Base.astro";
import archive from "../../data/archive.json";
import { memberEraLabels } from "../../lib/memberEras.ts";
import { absoluteUrl, SITE_URL } from "../../lib/seo";

type PersonProfile = {
  id: string;
  name?: { romanized?: string; original?: string };
  era?: string | null;
  role?: string;
  years_active?: string;
  active?: string | string[];
  [key: string]: unknown;
};

const profiles = (archive.people_profiles ?? []) as PersonProfile[];

export function getStaticPaths() {
  const items = (archive.people_profiles ?? []) as PersonProfile[];
  return items.map((profile) => ({
    params: { slug: profile.id.replace(/^person_/, "") },
  }));
}

const { slug } = Astro.params;
const profile = profiles.find((p) => p.id === `person_${slug}` || p.id === slug);

const title = profile?.name?.romanized ?? profile?.name?.original ?? slug;
const entityId = profile?.id ?? `person_${slug}`;
const memberDescription = profile
  ? `${title} — Malice Mizer ${profile.role ?? "member"} (${profile.years_active ?? "1992–2001"}). Band biography, photos, and linked archive entries.`
  : undefined;
const memberJsonLd = profile
  ? {
      "@context": "https://schema.org",
      "@type": "Person",
      name: title,
      alternateName: profile.name?.original,
      description: memberDescription,
      jobTitle: profile.role,
      url: absoluteUrl(`/members/${slug}`, Astro.site?.href ?? SITE_URL),
      memberOf: {
        "@type": "MusicGroup",
        name: "Malice Mizer",
        url: SITE_URL,
      },
    }
  : undefined;
---

{profile ? (
  <Base title={title} description={memberDescription} type="profile" jsonLd={memberJsonLd}>
    <Breadcrumbs
      items={[
        { label: "Members", href: "/members" },
        { label: title },
      ]}
    />
    <p class="muted entity-link">
      <a href={`/entity/${entityId}`}>Entity graph →</a>
    </p>

    <PersonProfile
      entity={{
        ...profile,
        era: memberEraLabels(profile.active) ?? profile.era ?? null,
      }}
      title={title}
      typeLabel="Member"
      typeColor="purple"
    />
  </Base>
) : (
  <Base title="Member not found" noindex>
    <p>Member profile not found.</p>
    <a href="/">← Back</a>
  </Base>
)}
