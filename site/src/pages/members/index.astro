---
import MemberCard from "../../components/MemberCard.astro";
import Base from "../../layouts/Base.astro";
import archive from "../../data/archive.json";
import { memberEraLabels } from "../../lib/memberEras.ts";

const entityIds: Record<string, string> = {
  mana: "person_mana",
  kozi: "person_kozi",
  yuki: "person_yuki",
  kami: "person_kami",
  gackt: "person_gackt",
  klaha: "person_klaha",
  tetsu: "person_tetsu",
  gaz: "person_gaz",
};

const memberOrder = ["tetsu", "mana", "kozi", "yuki", "gaz", "kami", "gackt", "klaha"];
const members = memberOrder
  .map((slug) => archive.people.members.find((m) => m.slug === slug))
  .filter(Boolean);
---

<Base
  title="Members"
  description="Malice Mizer band members — Mana, Közi, Yu~ki, Gaz, Kami, Gackt, Klaha, and Tetsu. Roles, eras, and profile pages for the visual kei group (1992–2001)."
>
  <h1 class="page-heading">Members</h1>
  <p class="muted">
    Core lineup across the Tetsu, Gackt, and Klaha eras. Select a member for biography, roles, and archive links.
  </p>

  <section class="members-section">
    <div class="members-grid">
      {members.map((member) => (
        <MemberCard
          name={member!.name}
          slug={member!.slug}
          role={member!.role}
          active={member!.active}
          portrait={member!.portrait_image}
          entityId={entityIds[member!.slug]}
          era={memberEraLabels(member!.active)}
        />
      ))}
    </div>
  </section>
</Base>
