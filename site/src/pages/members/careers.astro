---
import Base from "../../layouts/Base.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import CareerOverview from "../../components/CareerOverview.astro";
---

<Base
  title="Malice Mizer as Mother Band — careers timeline"
  description="Career timelines for Malice Mizer members — band memberships before, during, and after the mother band (1992–2001)."
>
  <Breadcrumbs
    items={[
      { label: "Members", href: "/members" },
      { label: "Careers timeline" },
    ]}
  />

  <h1 class="page-heading">Malice Mizer as Mother Band</h1>
  <p class="page-subheading">Careers timeline</p>
  <p class="muted" style="max-width: 40rem; margin-bottom: 1.25rem;">
    Malice Mizer spun many later projects as members moved on. Compare each member’s
    path into the band, through it, and into the bands and solo careers that followed.
  </p>

  <CareerOverview />

  <p class="muted" style="margin-top: 1.25rem; font-size: 0.88rem;">
    Open a <a href="/members">member profile</a> for a detailed timeline and biography.
    Membership years are approximate where sources give only year ranges.
  </p>
</Base>

<style>
  .page-subheading {
    margin: -0.35rem 0 0.85rem;
    font-family: var(--heading-font);
    font-size: 1.35rem;
    font-weight: 500;
    font-style: italic;
    color: var(--rose);
    letter-spacing: 0.02em;
  }
</style>
