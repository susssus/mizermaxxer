---
import ArchiveImage from "../../components/ArchiveImage.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Base from "../../layouts/Base.astro";
import translationsData from "../../data/translations.json";
import { issueForArticle, publicationName, scanHref, translationReviewLabel } from "../../lib/translations.ts";

export function getStaticPaths() {
  return translationsData.ids.map((id) => ({ params: { id } }));
}

const { id } = Astro.params;
const doc = translationsData.by_id[id as keyof typeof translationsData.by_id];

function pageScan(doc: Record<string, unknown>, pageNum: number): string | null {
  const paths = doc.scan_paths as string[] | undefined;
  if (!paths?.length) return null;
  const idx = pageNum - 1;
  if (idx >= 0 && idx < paths.length) return paths[idx];
  return null;
}

function speakerLabel(speaker: string): string {
  if (speaker === "interviewer") return "——";
  if (speaker === "all") return "All";
  return speaker.charAt(0).toUpperCase() + speaker.slice(1);
}

const translationTitle = doc?.title_en ?? doc?.title_ja ?? doc?.id;
const translationDescription = doc
  ? `English translation: ${doc.title_en ?? doc.title_ja} — Malice Mizer magazine interview or article from the research archive.`
  : undefined;
const needsReview = doc?.review_status === "needs_review";
const isReviewed = doc?.review_status === "reviewed";
const reviewLabel = translationReviewLabel(doc?.review_status ?? null);
const isDialogue =
  doc?.format === "dialogue" || (Array.isArray(doc?.dialogue) && doc.dialogue.length > 0);
const isPages = doc?.format === "pages" && Array.isArray(doc.pages);
const isOther = doc?.format === "other" || (!isDialogue && !isPages);
const issueRef = issueForArticle(doc?.article_id as string | undefined);
const breadcrumbItems = [
  { label: "Archive", href: "/" },
  ...(issueRef
    ? [
        {
          label: publicationName(issueRef.publication),
          href: issueRef.publication === "flyers" ? "/flyers" : "/",
        },
        { label: issueRef.publicationDate, href: `/issue/${issueRef.issueId}` },
      ]
    : []),
  { label: translationTitle as string },
];
const pageToc =
  doc?.format === "pages" && Array.isArray(doc.pages)
    ? doc.pages.map((page) => ({
        id: `page-${page.page}`,
        label: page.section ? `Page ${page.page}: ${page.section}` : `Page ${page.page}`,
      }))
    : [];
---

{doc && (
  <Base title={translationTitle} description={translationDescription} type="article">
    <Breadcrumbs items={breadcrumbItems} />

    {issueRef && (
      <p class="issue-link muted">
        Source issue: <a href={`/issue/${issueRef.issueId}`}>{publicationName(issueRef.publication)} · {issueRef.publicationDate}</a>
      </p>
    )}

    {needsReview && (
      <p class="review-notice card" role="status">
        Raw translation from scan transcriptions — not yet reviewed. Verify against the original
        Japanese before citing.
      </p>
    )}

    <header class="translation-header card">
      <h1>{doc.title_en ?? doc.title_ja}</h1>
      {doc.title_ja && doc.title_en && doc.title_ja !== doc.title_en && (
        <p class="title-ja">{doc.title_ja}</p>
      )}
      {doc.subtitle && <p class="subtitle">{doc.subtitle}</p>}
      <dl class="meta">
        {doc.publication && (
          <>
            <dt>Publication</dt>
            <dd>{doc.publication}{doc.issue_number ? ` #${doc.issue_number}` : ""}</dd>
          </>
        )}
        {doc.publication_date && (
          <>
            <dt>Date</dt>
            <dd>{doc.publication_date}</dd>
          </>
        )}
        {(doc.page_count || (!Array.isArray(doc.pages) && doc.pages) || doc.scan_paths?.length) && (
          <>
            <dt>Pages</dt>
            <dd>
              {doc.page_count
                ?? (!Array.isArray(doc.pages) ? doc.pages : null)
                ?? (Array.isArray(doc.pages) ? doc.pages.length : null)
                ?? doc.scan_paths?.length}
            </dd>
          </>
        )}
        {(doc.writer_en || doc.writer_ja || doc.writers_en) && (
          <>
            <dt>Writer</dt>
            <dd>{doc.writer_en ?? doc.writers_en ?? doc.writer_ja}</dd>
          </>
        )}
        {doc.translator && (
          <>
            <dt>Translator</dt>
            <dd>{doc.translator}</dd>
          </>
        )}
        {reviewLabel && (
          <>
            <dt>Review</dt>
            <dd>
              <span
                class={`badge ${doc.review_status}`}
                title={
                  isReviewed
                    ? "Translation reviewed against source"
                    : "Raw transcription — verify against the Japanese original"
                }
              >
                {reviewLabel}
              </span>
            </dd>
          </>
        )}
      </dl>
      {doc.license_notes && <p class="muted license">{doc.license_notes}</p>}
      {doc.license === "CC-BY-NC-4.0" && (
        <p class="muted license">
          English translation © Mizermaxxer contributors ·{" "}
          <a href="/legal">CC BY-NC 4.0</a>
          {" · "}
          <a href="https://creativecommons.org/licenses/by-nc/4.0/" target="_blank" rel="license noopener">
            license text
          </a>
        </p>
      )}
    </header>

    {isDialogue && Array.isArray(doc.scan_paths) && doc.scan_paths[0] && (
      <section class="card translation-block">
        <ArchiveImage
          src={doc.scan_paths[0] as string}
          alt={doc.title_en ?? doc.title_ja ?? "Scan"}
          caption={doc.title_en ?? doc.title_ja}
          variant="inline"
        />
      </section>
    )}

    {isDialogue && doc.intro && (
      <section class="card translation-block">
        <h2>Introduction</h2>
        {doc.intro.ja && (
          <div class="lang-block">
            <span class="lang-tag">Japanese</span>
            <p class="ja-text" lang="ja">{doc.intro.ja}</p>
          </div>
        )}
        {doc.intro.romaji && (
          <div class="lang-block">
            <span class="lang-tag">Romaji</span>
            <p class="romaji-text">{doc.intro.romaji}</p>
          </div>
        )}
        {doc.intro.en && (
          <div class="lang-block">
            <span class="lang-tag">English</span>
            <p>{doc.intro.en}</p>
          </div>
        )}
      </section>
    )}

    {isDialogue && doc.dialogue && (
      <section class="card translation-block">
        <h2>Interview</h2>
        <div class="dialogue-list">
          {doc.dialogue.map((line) => (
            <article class="dialogue-line">
              <p class="speaker">{speakerLabel(line.speaker ?? "unknown")}</p>
              {line.ja && (
                <div class="lang-block">
                  <span class="lang-tag">JA</span>
                  <p class="ja-text" lang="ja">{line.ja}</p>
                </div>
              )}
              {line.romaji && (
                <div class="lang-block">
                  <span class="lang-tag">Romaji</span>
                  <p class="romaji-text">{line.romaji}</p>
                </div>
              )}
              {line.en && (
                <div class="lang-block">
                  <span class="lang-tag">EN</span>
                  <p>{line.en}</p>
                </div>
              )}
            </article>
          ))}
        </div>
      </section>
    )}

    {isDialogue && doc.sidebar && (
      <section class="card translation-block">
        <h2>Sidebar</h2>
        {doc.sidebar.ja && (
          <div class="lang-block">
            <span class="lang-tag">Japanese</span>
            <p class="ja-text" lang="ja">{doc.sidebar.ja}</p>
          </div>
        )}
        {doc.sidebar.romaji && (
          <div class="lang-block">
            <span class="lang-tag">Romaji</span>
            <p class="romaji-text">{doc.sidebar.romaji}</p>
          </div>
        )}
        {doc.sidebar.en && (
          <div class="lang-block">
            <span class="lang-tag">English</span>
            <p>{doc.sidebar.en}</p>
          </div>
        )}
      </section>
    )}

    {isDialogue && doc.photo_spread_note && (
      <section class="card translation-block">
        <h2>Photo spread note</h2>
        {doc.photo_spread_note.ja && (
          <div class="lang-block">
            <span class="lang-tag">Japanese</span>
            <p class="ja-text" lang="ja">{doc.photo_spread_note.ja}</p>
          </div>
        )}
        {doc.photo_spread_note.romaji && (
          <div class="lang-block">
            <span class="lang-tag">Romaji</span>
            <p class="romaji-text">{doc.photo_spread_note.romaji}</p>
          </div>
        )}
        {doc.photo_spread_note.en && (
          <div class="lang-block">
            <span class="lang-tag">English</span>
            <p>{doc.photo_spread_note.en}</p>
          </div>
        )}
      </section>
    )}

    {isOther && Array.isArray(doc.scan_paths) && doc.scan_paths[0] && (
      <section class="card translation-block">
        <ArchiveImage
          src={doc.scan_paths[0] as string}
          alt={doc.title_en ?? doc.title_ja ?? "Scan"}
          caption={doc.title_en ?? doc.title_ja}
          variant="inline"
        />
      </section>
    )}

    {isOther && Array.isArray(doc.content) && (
      <section class="pages-list">
        {doc.content.map((block, index) => (
          <article class="card translation-page" id={`block-${index + 1}`}>
            {block.type && (
              <h2 class="section-label">{String(block.type).replaceAll("_", " ")}</h2>
            )}
            {block.ja && (
              <div class="lang-block">
                <span class="lang-tag">Japanese</span>
                <p class="ja-text" lang="ja">{block.ja}</p>
              </div>
            )}
            {block.romaji && (
              <div class="lang-block">
                <span class="lang-tag">Romaji</span>
                <p class="romaji-text">{block.romaji}</p>
              </div>
            )}
            {block.en && (
              <div class="lang-block">
                <span class="lang-tag">English</span>
                <p>{block.en}</p>
              </div>
            )}
          </article>
        ))}
      </section>
    )}

    {isOther && Array.isArray(doc.tour_dates) && doc.tour_dates.length > 0 && (
      <section class="card translation-block">
        <h2>Tour dates</h2>
        <table>
          <thead>
            <tr>
              <th>Date</th>
              <th>Day</th>
              <th>Venue (JA)</th>
              <th>Venue (EN)</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            {doc.tour_dates.map((row) => (
              <tr>
                <td>{row.date}</td>
                <td>{row.day ?? "—"}</td>
                <td>{row.venue_ja ?? "—"}</td>
                <td>{row.venue_en ?? "—"}</td>
                <td>{row.status ? row.status.replaceAll("_", " ") : "—"}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>
    )}

    {isOther && doc.footer && (
      <section class="card translation-block">
        <h2>Footer</h2>
        {doc.footer.ja && (
          <div class="lang-block">
            <span class="lang-tag">Japanese</span>
            <p class="ja-text" lang="ja">{doc.footer.ja}</p>
          </div>
        )}
        {doc.footer.romaji && (
          <div class="lang-block">
            <span class="lang-tag">Romaji</span>
            <p class="romaji-text">{doc.footer.romaji}</p>
          </div>
        )}
        {doc.footer.en && (
          <div class="lang-block">
            <span class="lang-tag">English</span>
            <p>{doc.footer.en}</p>
          </div>
        )}
      </section>
    )}

    {pageToc.length > 1 && (
      <nav class="card page-toc" aria-label="Page contents">
        <h2 class="toc-heading">Contents</h2>
        <ol>
          {pageToc.map((entry) => (
            <li><a href={`#${entry.id}`}>{entry.label}</a></li>
          ))}
        </ol>
      </nav>
    )}

    {isPages && (
      <section class="pages-list">
        {doc.pages.map((page) => {
          const scan = pageScan(doc, page.page as number);
          return (
            <article class="card translation-page" id={`page-${page.page}`}>
              <h2>
                Page {page.page}
                {page.section && <span class="section-label"> — {page.section}</span>}
              </h2>
              {scan && (
                <ArchiveImage
                  src={scan}
                  alt={`Page ${page.page}`}
                  caption={`Page ${page.page}`}
                  variant="inline"
                />
              )}
              {page.ja && (
                <div class="lang-block">
                  <span class="lang-tag">Japanese</span>
                  <p class="ja-text" lang="ja">{page.ja}</p>
                </div>
              )}
              {page.romaji && (
                <div class="lang-block">
                  <span class="lang-tag">Romaji</span>
                  <p class="romaji-text">{page.romaji}</p>
                </div>
              )}
              {page.en && (
                <div class="lang-block">
                  <span class="lang-tag">English</span>
                  <p>{page.en}</p>
                </div>
              )}
            </article>
          );
        })}
      </section>
    )}

    {doc.source_scan_gallery && (
      <p class="muted source-link">
        <a href={doc.source_scan_gallery as string} target="_blank" rel="noopener">
          Original scan gallery on Cantavanda
        </a>
      </p>
    )}
  </Base>
)}

<style>
  .review-notice {
    margin: 0 0 1rem;
    padding: 0.85rem 1rem;
    border-left: 3px solid var(--rose);
    background: color-mix(in srgb, var(--rose) 8%, transparent);
    color: var(--text);
    font-size: 0.95rem;
    line-height: 1.5;
  }
  .translation-header h1 {
    margin: 0 0 0.25rem;
    font-size: 1.75rem;
  }
  .title-ja {
    font-size: 1.1rem;
    color: var(--muted);
    margin: 0 0 0.5rem;
  }
  .subtitle {
    font-style: italic;
    color: var(--rose);
    margin: 0 0 1rem;
  }
  .meta {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.25rem 1rem;
    margin: 1rem 0 0;
    font-size: 0.95rem;
  }
  .meta dt {
    color: var(--muted);
    font-weight: 600;
  }
  .meta dd {
    margin: 0;
  }
  .license {
    margin-top: 1rem;
    font-size: 0.85rem;
    border-top: 1px solid var(--border);
    padding-top: 0.75rem;
  }
  .translation-block {
    margin-top: 1rem;
  }
  .translation-block h2 {
    margin-top: 0;
    font-size: 1.25rem;
  }
  .pages-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1rem;
  }
  .translation-page h2 {
    margin-top: 0;
    font-size: 1.15rem;
  }
  .section-label {
    font-weight: 400;
    color: var(--muted);
    font-size: 0.95rem;
  }
  .lang-block {
    margin: 0.75rem 0;
  }
  .lang-tag {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--rose);
    margin-bottom: 0.25rem;
  }
  .ja-text {
    font-family: "Hiragino Mincho ProN", "Yu Mincho", "MS Mincho", serif;
    line-height: 1.7;
  }
  .romaji-text {
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.6;
  }
  .dialogue-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .dialogue-line {
    border-left: 3px solid var(--border);
    padding-left: 1rem;
  }
  .speaker {
    font-weight: 600;
    margin: 0 0 0.35rem;
    color: var(--accent);
  }
  .source-link {
    margin-top: 2rem;
    text-align: center;
    font-size: 0.9rem;
  }
  .issue-link {
    margin: 0 0 1rem;
    font-size: 0.9rem;
  }
  .page-toc {
    margin-top: 1rem;
  }
  .toc-heading {
    margin: 0 0 0.75rem;
    font-size: 1rem;
  }
  .page-toc ol {
    margin: 0;
    padding-left: 1.25rem;
  }
  .page-toc li + li {
    margin-top: 0.35rem;
  }
</style>
