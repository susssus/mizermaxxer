---
import Base from "../../layouts/Base.astro";
import StatCard from "../../components/StatCard.astro";
import TriggerWarning from "../../components/TriggerWarning.astro";
import archive from "../../data/archive.json";

const songMap = new Map(archive.songs.map((song) => [song.id, song]));
---

<Base
  title="Videos"
  description="Malice Mizer music videos, TV performances, and live footage — PVs, promotional clips, and linked YouTube and archive sources."
>
  <h1 class="page-heading">Videos</h1>
  <p class="muted" style="margin-bottom: 1rem;">
    Physical VHS/DVD/Blu-ray releases are catalogued on the{" "}
    <a href="/discography">discography page</a>. This page lists online PVs, TV appearances, and live footage.
  </p>
  <section class="stats">
    <StatCard value={archive.stats.video_count} label="Videos catalogued" preset="all" />
  </section>

  <section class="card" id="videos-list">
    <h2>Online video catalog</h2>
    <table>
      <thead>
        <tr>
          <th>Title</th>
          <th>Type</th>
          <th>Song</th>
          <th>Platform</th>
          <th>Link</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        {archive.videos.map((video) => (
          <tr>
            <td>{video.title_en}{video.title_ja && <><br /><span class="muted">{video.title_ja}</span></>}</td>
            <td>{video.type.replaceAll("_", " ")}</td>
            <td>{video.song ? songMap.get(video.song)?.title_en ?? video.song : "—"}</td>
            <td>{video.platform ?? "—"}</td>
            <td>
              <a href={video.url} target="_blank" rel="noopener noreferrer">Watch</a>
              {video.trigger_warnings?.length ? (
                <> <TriggerWarning warnings={video.trigger_warnings} /></>
              ) : null}
            </td>
            <td><span class={`badge ${video.verification_status}`}>{video.verification_status.replaceAll("_", " ")}</span></td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section class="card" style="margin-top: 1rem;">
    <h3>External references</h3>
    <ul>
      {archive.references.map((reference) => (
        <li><a href={reference.url} target="_blank" rel="noopener noreferrer">{reference.title}</a></li>
      ))}
    </ul>
  </section>
</Base>

<script>
  document.querySelectorAll("[data-stat-preset]").forEach((button) => {
    button.addEventListener("click", () => {
      button.classList.add("stat--active");
      document.getElementById("videos-list")?.scrollIntoView({ behavior: "smooth", block: "start" });
    });
  });
</script>
