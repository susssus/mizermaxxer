---
import FilterBar from "../components/FilterBar.astro";
import ImageSourceNote from "../components/ImageSourceNote.astro";
import MemberCard from "../components/MemberCard.astro";
import ProfileMeta from "../components/ProfileMeta.astro";
import StatCard from "../components/StatCard.astro";
import Base from "../layouts/Base.astro";
import archive from "../data/archive.json";
import { absoluteUrl, DEFAULT_DESCRIPTION, SITE_NAME, SITE_URL } from "../lib/seo";
import { memberEraLabels } from "../lib/memberEras.ts";
import { memberPortraitForSlug } from "../lib/memberPortrait.ts";
import { translationSlug } from "../lib/translations.ts";

const pubMap = new Map(archive.publications.map((pub) => [pub.slug, pub]));

const rows = archive.issues
  .flatMap((issue) =>
    issue.articles.map((article) => ({
      issue,
      article,
      publication: pubMap.get(issue.publication),
    }))
  )
  .sort((a, b) => a.issue.publication_date.localeCompare(b.issue.publication_date));

const localTranslationCount = rows.filter(({ article }) =>
  Boolean(translationSlug(article.translation_url))
).length;

const byPublication = archive.publications
  .map((pub) => ({
    name: pub.name_en,
    slug: pub.slug,
    count: archive.issues.filter((issue) => issue.publication === pub.slug).length,
    priority: pub.priority,
  }))
  .filter((entry) => entry.count > 0)
  .sort((a, b) => b.count - a.count);

const coverageGaps = archive.publications
  .map((pub) => ({
    name: pub.name_en,
    slug: pub.slug,
    priority: pub.priority,
  }))
  .filter((pub) => archive.issues.every((issue) => issue.publication !== pub.slug))
  .sort((a, b) => a.priority - b.priority);

const vkgyPriorityGaps = ["uv", "m-gazette", "j-rock-magazine", "pop-beat", "pati-pati", "b-pass", "vicious", "band-yarouze"];

const entityIds: Record<string, string> = {
  mana: "person_mana",
  kozi: "person_kozi",
  yuki: "person_yuki",
  kami: "person_kami",
  gackt: "person_gackt",
  klaha: "person_klaha",
  tetsu: "person_tetsu",
  gaz: "person_gaz",
};

const memberOrder = ["tetsu", "mana", "kozi", "yuki", "gaz", "kami", "gackt", "klaha"];
const featuredMembers = memberOrder
  .map((slug) => archive.people.members.find((m) => m.slug === slug))
  .filter(Boolean);

const featuredFlyers = archive.issues
  .filter((issue) => issue.publication === "flyers")
  .flatMap((issue) =>
    issue.articles
      .filter((article) => article.scan_url)
      .map((article) => ({
        issue,
        article,
        title: article.title_en ?? article.title_ja ?? issue.publication_date,
      }))
  )
  .sort((a, b) => b.issue.publication_date.localeCompare(a.issue.publication_date))
  .slice(0, 6);

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: SITE_NAME,
    url: SITE_URL,
    description: DEFAULT_DESCRIPTION,
    inLanguage: "en",
    publisher: {
      "@type": "Organization",
      name: SITE_NAME,
      url: SITE_URL,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "MusicGroup",
    name: "Malice Mizer",
    alternateName: "マリスミゼール",
    genre: ["Visual kei", "J-rock", "Gothic rock"],
    foundingDate: "1992",
    dissolutionDate: "2001",
    url: SITE_URL,
    image: absoluteUrl("/images/members/hero.webp"),
    description:
      "Japanese visual kei band active 1992–2001, known for theatrical performances and albums including Merveilles and Bara no Seidou.",
  },
];
---

<Base
  title="Bibliography"
  description={DEFAULT_DESCRIPTION}
  jsonLd={jsonLd}
>
  <h1 class="page-heading visually-hidden">Bibliography</h1>
  <section class="hero hero--split">
    <div class="hero__intro">
      <h2 class="hero__title">MALICE MIZER</h2>
      <p class="hero__tagline">Band archive · print, discography & live history · 1992–2001</p>
    </div>
    <figure class="hero__figure">
      <img
        class="hero__image"
        src="/images/members/hero.webp"
        alt="MALICE MIZER — promotional photograph"
        loading="eager"
        decoding="async"
      />
    </figure>
  </section>

  <ProfileMeta stats={archive.stats} />

  <section class="members-section">
    <h2 class="section-heading">Members</h2>
    <div class="members-grid">
      {featuredMembers.map((member) => (
        <MemberCard
          name={member!.name}
          slug={member!.slug}
          role={member!.role}
          active={member!.active}
          portrait={memberPortraitForSlug(member!.slug, archive)}
          entityId={entityIds[member!.slug]}
          era={memberEraLabels(member!.active)}
        />
      ))}
    </div>
  </section>

  <section class="stats">
    <StatCard value={archive.stats.issue_count} label="Issues tracked" preset="all" />
    <StatCard value={archive.stats.album_count + archive.stats.single_count} label="Releases" href="/discography" />
    <StatCard value={archive.stats.concert_count} label="Concerts" href="/gigs" />
    <StatCard value={archive.stats.verified_issue_count} label="Verified issues" preset="verified" />
    <StatCard value={archive.stats.scan_count} label="Scans available" preset="scans" />
    <StatCard value={localTranslationCount} label="Local translations" preset="translations" />
  </section>

  {featuredFlyers.length > 0 && (
    <section>
      <h2 class="section-heading">Featured flyers</h2>
      <div class="flyer-grid">
        {featuredFlyers.map(({ issue, article, title }) => (
          <figure class="flyer-card flyer-card--featured">
            <a class="flyer-card__link" href={`/issue/${issue.id}`}>
              <img src={`/${article.scan_url}`} alt={title} loading="lazy" />
            </a>
            <figcaption class="flyer-card__meta">
              <a href={`/issue/${issue.id}`}><strong>{title}</strong></a>
              <span>{issue.publication_date}</span>
              <ImageSourceNote src={article.scan_url} compact />
            </figcaption>
          </figure>
        ))}
      </div>
      <p><a href="/flyers">View all flyers →</a></p>
    </section>
  )}

  <section id="bibliography">
    <FilterBar />

    <div class="table-scroll">
    <table>
    <thead>
      <tr>
        <th>Date</th>
        <th>Publication</th>
        <th>Issue</th>
        <th>Type</th>
        <th>Nature</th>
        <th>Title</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      {rows.map(({ issue, article, publication }) => (
        <tr
          data-row
          data-year={issue.publication_date.slice(0, 4)}
          data-publication={issue.publication}
          data-type={article.type}
          data-content-nature={article.content_nature ?? ""}
          data-promo-subtype={article.promotional_subtype ?? ""}
          data-members={article.members.join(",")}
          data-status={issue.verification_status}
          data-scan={String(article.scan_available)}
          data-translation={String(Boolean(translationSlug(article.translation_url)))}
        >
          <td>{issue.publication_date}</td>
          <td>{publication?.name_en ?? issue.publication}</td>
          <td><a href={`/issue/${issue.id}`}>{issue.issue_number ?? issue.id}</a></td>
          <td>
            {article.type.replaceAll("_", " ")}
            {article.promotional_subtype ? (
              <div class="muted" style="font-size:0.78rem;">{article.promotional_subtype.replaceAll("_", " ")}</div>
            ) : null}
          </td>
          <td>{article.content_nature?.replaceAll("_", " ") ?? "—"}</td>
          <td>{article.title_en ?? article.title_ja ?? "—"}</td>
          <td><span class={`badge ${issue.verification_status}`}>{issue.verification_status.replaceAll("_", " ")}</span></td>
        </tr>
      ))}
    </tbody>
    </table>
    </div>
  </section>

  <section class="card" style="margin-top: 2rem;">
    <h2>Coverage by publication</h2>
    <ul>
      {byPublication.map((entry) => (
        <li>{entry.name}: {entry.count} issue stubs</li>
      ))}
    </ul>
    {coverageGaps.length > 0 && (
      <>
        <h3 style="margin-top: 1.25rem; font-size: 1rem;">Research gaps</h3>
        <p class="muted" style="margin-top: 0;">
          Publications in catalog with no issue stubs yet. Priority targets flagged by{" "}
          <a href="https://vk.gy/artists/malice-mizer/" target="_blank" rel="noopener">vk.gy</a> timeline:
        </p>
        <ul>
          {coverageGaps.map((entry) => (
            <li>
              {entry.name}
              {vkgyPriorityGaps.includes(entry.slug) && (
                <span class="badge needs_verification" style="margin-left: 0.35rem;">vk.gy priority</span>
              )}
            </li>
          ))}
        </ul>
      </>
    )}
    <p class="muted">Generated {archive.generated_at}</p>
  </section>
</Base>

<script>
  const statButtons = Array.from(document.querySelectorAll("[data-stat-preset]"));

  function setActiveStat(preset: string) {
    statButtons.forEach((button) => {
      const active = button.getAttribute("data-stat-preset") === preset;
      button.classList.toggle("stat--active", active);
      button.setAttribute("aria-pressed", active ? "true" : "false");
    });
  }

  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  statButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const preset = button.getAttribute("data-stat-preset") ?? "all";
      window.bibliographyFilters?.applyPreset(preset);
      setActiveStat(preset);
      document.getElementById("bibliography")?.scrollIntoView({
        behavior: prefersReducedMotion ? "auto" : "smooth",
        block: "start",
      });
    });
  });
</script>

<style>
  .page-heading.visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
