---
import FlyerLightbox from "../../components/FlyerLightbox.astro";
import ImageSourceNote from "../../components/ImageSourceNote.astro";
import StatCard from "../../components/StatCard.astro";
import Base from "../../layouts/Base.astro";
import archive from "../../data/archive.json";
import { imageAttributionForSrc } from "../../lib/imageAttribution.ts";

function handbillLabel(article: (typeof archive.issues)[0]["articles"][0]) {
  const subject = article.promotional_subject?.replaceAll("_", " ") ?? "promotional";
  return `${subject} handbill`;
}

const flyerIssues = archive.issues
  .filter((issue) => issue.publication === "flyers")
  .flatMap((issue) =>
    issue.articles
      .filter(
        (article) =>
          article.promotional_carrier === "standalone_handbill" ||
          article.promotional_carrier === "standalone" ||
          (article.type === "flyer" && article.content_nature === "promotional")
      )
      .map((article) => ({
        issue,
        article,
        title: article.title_en ?? article.title_ja ?? "Untitled handbill",
        year: issue.publication_date.slice(0, 4),
        subject: article.promotional_subject ?? "other",
        subjectLabel: handbillLabel(article),
      }))
  )
  .sort((a, b) => b.issue.publication_date.localeCompare(a.issue.publication_date));

const years = [...new Set(flyerIssues.map((entry) => entry.year))].sort();
const subjects = [...new Set(flyerIssues.map((entry) => entry.subject))].sort();
const withScans = flyerIssues.filter((entry) => entry.article.scan_url).length;
const gigHandbills = flyerIssues.filter((entry) => entry.subject === "live_gig").length;
const releaseHandbills = flyerIssues.filter(
  (entry) => ["single", "album", "video"].includes(entry.subject)
).length;
---

<Base
  title="Flyers"
  description="Malice Mizer standalone promotional handbills (チラシ) — gig, tour, and release flyers distributed at venues and indie shops (1992–2001)."
>
  <h1 class="page-heading">Flyers</h1>
  <p class="muted page-intro">
    Standalone handbills only. Magazine clippings and magazine ads are catalogued under{" "}
    <a href="/">Bibliography</a> and <a href="/issue/clippings-magazine-excerpts">Magazine clippings</a>.
  </p>
  <section class="stats">
    <StatCard value={flyerIssues.length} label="Handbills catalogued" preset="all" />
    <StatCard value={gigHandbills} label="Gig handbills" preset="all" />
    <StatCard value={releaseHandbills} label="Release handbills" preset="all" />
    <StatCard value={withScans} label="Scans available" preset="scans" />
    <StatCard value={years.length} label="Years covered" preset="all" />
  </section>

  <div class="filters" id="flyer-filters">
    <label>
      Year
      <select id="flyerYear">
        <option value="">All years</option>
        {years.map((year) => <option value={year}>{year}</option>)}
      </select>
    </label>
    <label>
      Subject
      <select id="flyerSubtype">
        <option value="">All subjects</option>
        {subjects.map((subject) => <option value={subject}>{subject.replaceAll("_", " ")}</option>)}
      </select>
    </label>
    <label>
      Scan
      <select id="flyerScan">
        <option value="">All</option>
        <option value="yes">Available</option>
        <option value="no">Pending</option>
      </select>
    </label>
  </div>

  <div class="flyer-grid flyer-grid--catalog" id="flyer-grid">
    {flyerIssues.map(({ issue, article, title, year, subject, subjectLabel }) => {
      const attribution = article.scan_url
        ? imageAttributionForSrc(article.scan_url)
        : null;
      return (
      <article
        class="flyer-card"
        data-flyer-card
        data-year={year}
        data-subtype={subject}
        data-scan={article.scan_url ? "yes" : "no"}
      >
        {article.scan_url ? (
          <button
            type="button"
            class="flyer-card__thumb"
            data-flyer-open
            data-flyer-src={`/${article.scan_url}`}
            data-flyer-title={title}
            data-flyer-date={issue.publication_date}
            data-flyer-href={`/issue/${issue.id}`}
            data-flyer-source-name={attribution?.sourceName}
            data-flyer-source-url={attribution?.sourceUrl ?? undefined}
            aria-label={`View full scan: ${title}`}
          >
            <img
              src={`/${article.scan_url}`}
              alt=""
              loading="lazy"
              decoding="async"
              onerror="this.closest('.flyer-card__thumb')?.replaceWith(Object.assign(document.createElement('div'), {className: 'flyer-card__placeholder', innerHTML: '<span>✦</span><span>Scan unavailable</span>'}))"
            />
          </button>
        ) : (
          <div class="flyer-card__placeholder">
            <span>✦</span>
            <span>Scan pending</span>
          </div>
        )}
        <div class="flyer-card__meta">
          <a href={`/issue/${issue.id}`}><strong>{title}</strong></a>
          <span class="type-chip gray" style="font-size:0.62rem;display:inline-block;margin-top:0.2rem;">{subjectLabel}</span>
          <span>{issue.publication_date}</span>
          {article.scan_url && <ImageSourceNote src={article.scan_url} compact />}
        </div>
      </article>
    );
    })}
  </div>

  <FlyerLightbox />

  <p class="muted" style="margin-top: 1rem;">
    Release handbills catalogued from{" "}
    <a href="https://malice-mizer.info/flyers" target="_blank" rel="noopener">malice-mizer.info</a>.
    Early handbills from{" "}
    <a href="https://malicemeezer.neocities.org/vintage" target="_blank" rel="noopener">Malice Meezer</a>.
  </p>
</Base>

<style>
  .flyer-grid--catalog {
    grid-template-columns: repeat(auto-fill, minmax(108px, 1fr));
    gap: 0.75rem;
  }
  .flyer-grid--catalog .flyer-card__thumb {
    display: block;
    width: 100%;
    padding: 0;
    border: none;
    background: color-mix(in srgb, var(--accent) 4%, var(--surface));
    cursor: zoom-in;
  }
  .flyer-grid--catalog .flyer-card__thumb img {
    width: 100%;
    height: 140px;
    object-fit: cover;
    display: block;
  }
  .flyer-grid--catalog .flyer-card__meta a {
    color: inherit;
    text-decoration: none;
  }
  .flyer-grid--catalog .flyer-card__meta a:hover strong {
    color: var(--rose);
  }
  .flyer-grid--catalog .flyer-card__placeholder {
    height: 140px;
    aspect-ratio: auto;
  }
  .flyer-card__placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    aspect-ratio: 3 / 4;
    background: color-mix(in srgb, var(--rose) 6%, var(--surface));
    color: var(--muted);
    font-size: 0.82rem;
  }
  .flyer-card__placeholder span:first-child {
    color: var(--rose);
    font-size: 1.25rem;
  }
</style>

<script>
  const cards = Array.from(document.querySelectorAll("[data-flyer-card]"));
  const statButtons = Array.from(document.querySelectorAll("[data-stat-preset]"));

  function applyFlyerFilters() {
    const year = (document.getElementById("flyerYear") as HTMLSelectElement).value;
    const subtype = (document.getElementById("flyerSubtype") as HTMLSelectElement).value;
    const scan = (document.getElementById("flyerScan") as HTMLSelectElement).value;

    cards.forEach((card) => {
      const dataset = (card as HTMLElement).dataset;
      const matchesYear = !year || dataset.year === year;
      const matchesSubtype = !subtype || dataset.subtype === subtype;
      const matchesScan = !scan || dataset.scan === scan;
      (card as HTMLElement).style.display = matchesYear && matchesSubtype && matchesScan ? "" : "none";
    });
  }

  function applyFlyerPreset(preset: string) {
    const yearSelect = document.getElementById("flyerYear") as HTMLSelectElement;
    const scanSelect = document.getElementById("flyerScan") as HTMLSelectElement;

    yearSelect.value = "";
    scanSelect.value = preset === "scans" ? "yes" : "";
    (document.getElementById("flyerSubtype") as HTMLSelectElement).value = "";
    applyFlyerFilters();

    statButtons.forEach((button) => {
      button.classList.toggle(
        "stat--active",
        button.getAttribute("data-stat-preset") === preset
      );
    });

    document.getElementById("flyer-grid")?.scrollIntoView({ behavior: "smooth", block: "start" });
  }

  document.getElementById("flyerSubtype")?.addEventListener("change", () => {
    statButtons.forEach((button) => button.classList.remove("stat--active"));
    applyFlyerFilters();
  });
  document.getElementById("flyerYear")?.addEventListener("change", () => {
    statButtons.forEach((button) => button.classList.remove("stat--active"));
    applyFlyerFilters();
  });
  document.getElementById("flyerScan")?.addEventListener("change", () => {
    statButtons.forEach((button) => button.classList.remove("stat--active"));
    applyFlyerFilters();
  });

  statButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const preset = button.getAttribute("data-stat-preset") ?? "all";
      applyFlyerPreset(preset);
    });
  });
</script>
