---
import ArchiveImage from "../../components/ArchiveImage.astro";
import Base from "../../layouts/Base.astro";
import archive from "../../data/archive.json";
import { scanHref, translationHref, translationReviewLabel, translationReviewStatus } from "../../lib/translations.ts";

export function getStaticPaths() {
  return archive.issues.map((issue) => ({ params: { id: issue.id } }));
}

const { id } = Astro.params;
const issue = archive.issues.find((entry) => entry.id === id);
const publication = archive.publications.find((pub) => pub.slug === issue?.publication);
const isFlyer = issue?.publication === "flyers";
const previewArticle = issue?.articles.find((article) => article.scan_url);

const issueTitle = `${publication?.name_en ?? issue?.publication ?? "Issue"} — ${issue?.publication_date ?? ""}`.trim();
const issueDescription = issue
  ? `Malice Mizer coverage in ${publication?.name_en ?? issue.publication} (${issue.publication_date}) — articles, scans, and bibliography details.`
  : undefined;
---

{issue && (
  <Base title={issueTitle} description={issueDescription} type="article">
    <a class="back" href={isFlyer ? "/flyers" : "/"}>← Back to {isFlyer ? "flyers" : "archive"}</a>

    {isFlyer && issue.articles.some((a) => a.scan_url) && (
      <section class="card flyer-scans" style="margin-bottom: 1rem;">
        <h3>Flyer scans</h3>
        <div class="flyer-scans__grid">
          {issue.articles.filter((a) => a.scan_url).map((article) => {
            const tHref = translationHref(article.translation_url);
            const reviewStatus = translationReviewStatus(article.translation_url);
            const reviewLabel = translationReviewLabel(reviewStatus);
            return (
              <article class="flyer-scans__item">
                <ArchiveImage
                  src={article.scan_url}
                  alt={article.title_en ?? article.title_ja ?? "Flyer scan"}
                  caption={article.title_en ?? article.title_ja}
                  variant="inline"
                />
                {article.translation_available && tHref && (
                  <p class="flyer-scans__translation">
                    <a href={tHref}>English translation →</a>
                    {reviewLabel && (
                      <span
                        class={`badge ${reviewStatus}`}
                        title={
                          reviewStatus === "needs_review"
                            ? "Raw transcription — verify against the Japanese original"
                            : "Translation reviewed against source"
                        }
                      >
                        {reviewLabel}
                      </span>
                    )}
                  </p>
                )}
              </article>
            );
          })}
        </div>
      </section>
    )}

    {!isFlyer && previewArticle?.scan_url && (
      <section class="card" style="margin-bottom: 1rem;">
        <ArchiveImage
          src={previewArticle.scan_url}
          alt={previewArticle.title_en ?? previewArticle.title_ja ?? "Scan"}
          caption={previewArticle.title_en ?? previewArticle.title_ja}
          source="malice-mizer.info / Cantavanda"
          variant="inline"
        />
      </section>
    )}

    <section class="detail-grid">
      <div class="card">
        <h2>{publication?.name_en ?? issue.publication}</h2>
        <p><strong>Date:</strong> {issue.publication_date} ({issue.date_precision})</p>
        <p><strong>Issue number:</strong> {issue.issue_number ?? "Unknown"}</p>
        <p><strong>Volume:</strong> {issue.volume ?? "Unknown"}</p>
        <p>
          <strong>Status:</strong>
          <span class={`badge ${issue.verification_status}`}>{issue.verification_status.replaceAll("_", " ")}</span>
        </p>
        {issue.source_notes && <p class="muted">{issue.source_notes}</p>}
      </div>

      <div class="card">
        <h3>Research targets</h3>
        {issue.research_targets?.length ? (
          <ul>
            {issue.research_targets.map((target) => <li>{target}</li>)}
          </ul>
        ) : (
          <p class="muted">None listed.</p>
        )}
      </div>
    </section>

    <section class="card" style="margin-top: 1rem;">
      <h3>Articles</h3>
      <table>
        <thead>
          <tr>
            <th>Type</th>
            <th>Title</th>
            <th>Pages</th>
            <th>Members</th>
            <th>Scan</th>
            <th>Translation</th>
          </tr>
        </thead>
        <tbody>
          {issue.articles.map((article) => {
            const tHref = translationHref(article.translation_url);
            const isExternalTranslation = article.translation_url?.startsWith("http");
            const reviewStatus = translationReviewStatus(article.translation_url);
            const reviewLabel = translationReviewLabel(reviewStatus);
            return (
            <tr>
              <td>{article.type.replaceAll("_", " ")}</td>
              <td>{article.title_en ?? article.title_ja ?? "—"}</td>
              <td>{article.pages ?? "—"}</td>
              <td>{article.members.length ? article.members.join(", ") : "—"}</td>
              <td>
                {article.scan_url ? (
                  <a href={scanHref(article.scan_url) ?? "#"} target="_blank" rel="noopener">View scan</a>
                ) : article.scan_available ? (
                  "Yes"
                ) : (
                  "No"
                )}
              </td>
              <td>
                {article.translation_available && tHref ? (
                  <span class="translation-cell">
                    {isExternalTranslation ? (
                      <a href={tHref} target="_blank" rel="noopener">English (external)</a>
                    ) : (
                      <a href={tHref}>English</a>
                    )}
                    {reviewLabel && (
                      <span
                        class={`badge ${reviewStatus}`}
                        title={
                          reviewStatus === "needs_review"
                            ? "Raw transcription — verify against the Japanese original"
                            : "Translation reviewed against source"
                        }
                      >
                        {reviewLabel}
                      </span>
                    )}
                  </span>
                ) : (
                  "—"
                )}
              </td>
            </tr>
          );
          })}
        </tbody>
      </table>
    </section>

    <section class="card" style="margin-top: 1rem;">
      <h3>Changelog</h3>
      <ul>
        {issue.changelog.map((entry) => (
          <li>
            <strong>{entry.date}</strong> — {entry.action} ({entry.source}): {entry.notes}
          </li>
        ))}
      </ul>
    </section>
  </Base>
)}

<style>
  .flyer-scans h3 {
    margin-top: 0;
  }
  .flyer-scans__grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  }
  .flyer-scans__item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .flyer-scans__translation {
    margin: 0;
    font-size: 0.88rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
  }
  .flyer-scans__translation a {
    color: var(--rose);
    text-decoration: none;
  }
  .flyer-scans__translation a:hover {
    text-decoration: underline;
  }
  .translation-cell {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
  }
</style>
