---
import PersonProfile from "../../components/PersonProfile.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import EntityEgoGraph from "../../components/EntityEgoGraph.astro";
import NotFound from "../../components/NotFound.astro";
import TriggerWarning from "../../components/TriggerWarning.astro";
import Base from "../../layouts/Base.astro";
import linksIndex from "../../data/links_index.json";

export function getStaticPaths() {
  return linksIndex.browse.map((row) => ({ params: { id: row.id } }));
}

const { id } = Astro.params;
const row = linksIndex.browse.find((entry) => entry.id === id);
const entity = linksIndex.entities_by_id[id as string];
const links = linksIndex.linked_entities[id as string]?.all ?? [];
const titleById = Object.fromEntries(linksIndex.browse.map((entry) => [entry.id, entry.title]));
const typeColorById = Object.fromEntries(
  linksIndex.browse.map((entry) => [entry.id, entry.type_color]),
);
const entityDescription = row
  ? `${row.title} — ${row.type_label} in the Malice Mizer research archive. Linked releases, performances, and related entities.`
  : undefined;
---

{row && entity ? (
  <Base title={row.title} description={entityDescription} type="article">
    <Breadcrumbs
      items={[
        { label: "Browse", href: "/browse" },
        { label: row.title },
      ]}
    />

    <section class="detail-grid">
      {entity.type === "person" ? (
        <PersonProfile
          entity={entity}
          title={row.title}
          typeLabel={row.type_label}
          typeColor={row.type_color}
        />
      ) : (
      <div class="card">
        <p><span class={`type-chip ${row.type_color}`}>{row.type_label}</span></p>
        <h2>{row.title}</h2>
        <p class="muted">{row.id}</p>
        <p><strong>Date:</strong> {row.date ?? "—"}</p>
        <p>
          <strong>Status:</strong>
          <span class={`badge ${row.status}`}>{row.status.replaceAll("_", " ")}</span>
        </p>
        <p><strong>Links:</strong> {row.link_count}</p>

        {entity.type === "appearance" && (
          <>
            <p><strong>Medium:</strong> {entity.appearance_type} · {entity.format}</p>
            {entity.broadcast?.network && (
              <p><strong>Network:</strong>{" "}
                <a href={`/entity/${entity.broadcast.network}`}>
                  {titleById[entity.broadcast.network] ?? entity.broadcast.network}
                </a>
                {entity.broadcast.program ? ` · ${entity.broadcast.program}` : ""}
                {entity.broadcast.channel ? ` (${entity.broadcast.channel})` : ""}
              </p>
            )}
            {entity.songs_performed?.length > 0 && (
              <p><strong>Songs:</strong>{" "}
                {entity.songs_performed.map((songId, i) => (
                  <>
                    {i > 0 ? ", " : ""}
                    <a href={`/entity/${songId}`}>{titleById[songId] ?? songId}</a>
                  </>
                ))}
              </p>
            )}
            {entity.performances?.length > 0 && (
              <div>
                <strong>Footage:</strong>
                <ul>
                  {entity.performances.map((perf) => (
                    <li>
                      <a href={perf.url} target="_blank" rel="noopener">{perf.title ?? perf.url}</a>
                      {perf.trigger_warnings?.length ? (
                        <> <TriggerWarning warnings={perf.trigger_warnings} /></>
                      ) : null}
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </>
        )}
      </div>
      )}

      {entity.facts?.length > 0 && (
        <div class="card">
          <h3>Facts</h3>
          <ul>
            {entity.facts.map((fact) => (
              <li>
                <p>{fact.statement.trim()}</p>
                <p class="muted">
                  {fact.status} · {fact.confidence} confidence
                  {fact.sources?.length ? ` · sources: ${fact.sources.join(", ")}` : ""}
                </p>
              </li>
            ))}
          </ul>
        </div>
      )}
    </section>

    <EntityEgoGraph
      centerId={row.id}
      centerTitle={row.title}
      links={links}
      titleById={titleById}
      typeColorById={typeColorById}
    />

    <section class="card" style="margin-top: 1rem;">
      <h3>Linked entities</h3>
      {links.length ? (
        <table>
          <thead>
            <tr>
              <th>Relation</th>
              <th>Entity</th>
              <th>Type</th>
              <th>Active</th>
            </tr>
          </thead>
          <tbody>
            {links.map((link) => {
              const target = linksIndex.browse.find((entry) => entry.id === link.entity_id);
              const active = link.active;
              const activeLabel = active?.start
                ? `${active.start}–${active.end ?? "present"}`
                : "—";
              return (
                <tr>
                  <td>
                    <span class={`type-chip ${link.color || "gray"}`} style="font-size:0.65rem;">
                      {link.label || link.relation}
                    </span>
                    {link.role && <span class="muted" style="margin-left:0.35rem;font-size:0.75rem;">{link.role}</span>}
                  </td>
                  <td><a href={`/entity/${link.entity_id}`}>{titleById[link.entity_id] ?? link.entity_id}</a></td>
                  <td>{target?.type_label ?? "—"}</td>
                  <td class="muted" style="font-variant-numeric:tabular-nums;white-space:nowrap;">{activeLabel}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      ) : (
        <p class="muted">No linked entities.</p>
      )}
    </section>
  </Base>
) : (
  <NotFound
    title="Entity not found"
    message="No entity matches that ID in the research graph."
    backHref="/browse"
    backLabel="← Back to browse"
  />
)}
