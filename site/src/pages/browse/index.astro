---
import BrowseFilters from "../../components/BrowseFilters.astro";
import StatCard from "../../components/StatCard.astro";
import Base from "../../layouts/Base.astro";
import linksIndex from "../../data/links_index.json";

const rows = linksIndex.browse;
---

<Base title="Browse — Malice Mizer Research Archive">
  <section class="stats">
    <StatCard value={rows.length} label="Entities shown" preset="all" />
    <StatCard value={linksIndex.entity_count} label="Total entities" preset="all" />
    <StatCard value={linksIndex.edge_count} label="Resolved links" preset="linked" />
  </section>

  <BrowseFilters />

  <table id="browse-table">
    <thead class="sortable">
      <tr>
        <th data-sort="type">Type</th>
        <th data-sort="title">Title</th>
        <th data-sort="date">Date</th>
        <th data-sort="status">Status</th>
        <th data-sort="link_count">Links</th>
      </tr>
    </thead>
    <tbody>
      {rows.map((row) => (
        <tr
          data-browse-row
          data-id={row.id.toLowerCase()}
          data-type={row.type}
          data-title={row.title.toLowerCase()}
          data-date={row.date || ""}
          data-year={row.year || ""}
          data-status={row.status}
          data-link_count={String(row.link_count)}
        >
          <td>
            <span class={`type-chip ${row.type_color}`}>{row.type_label}</span>
          </td>
          <td>
            <a href={`/entity/${row.id}`}>{row.title}</a>
            <div class="muted" style="font-size:0.78rem;margin-top:0.15rem;">{row.id}</div>
          </td>
          <td>{row.date ?? "—"}</td>
          <td>
            <span class={`badge ${row.status}`}>{row.status.replaceAll("_", " ")}</span>
          </td>
          <td class="link-count">{row.link_count}</td>
        </tr>
      ))}
    </tbody>
  </table>

  <p class="muted" style="margin-top:1rem;">
    <span id="browse-count">{rows.length}</span> entities shown. Generated {linksIndex.generated_at}. Links column = unique related entities from the resolved graph.
  </p>
</Base>

<script>
  const statButtons = Array.from(document.querySelectorAll("[data-stat-preset]"));

  statButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const preset = button.getAttribute("data-stat-preset") ?? "all";
      window.browseFilters?.applyPreset(preset);

      statButtons.forEach((btn) => {
        btn.classList.toggle(
          "stat--active",
          btn.getAttribute("data-stat-preset") === preset
        );
      });

      document.getElementById("browse-table")?.scrollIntoView({ behavior: "smooth", block: "start" });
    });
  });
</script>
