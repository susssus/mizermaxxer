---
interface Props {
  src?: string | null;
  alt: string;
  caption?: string | null;
  source?: string | null;
  class?: string;
  variant?: "inline" | "hero" | "thumb" | "cover";
}

const {
  src,
  alt,
  caption,
  source,
  class: className = "",
  variant = "inline",
} = Astro.props;

function resolveSrc(path?: string | null): string | null {
  if (!path) return null;
  if (path.startsWith("http://") || path.startsWith("https://")) return path;
  if (path.startsWith("images/")) return `/${path}`;
  return path.startsWith("/") ? path : `/${path}`;
}

const resolved = resolveSrc(src);
---

<figure class={`archive-image archive-image--${variant} ${className}`.trim()}>
  {resolved ? (
    <img src={resolved} alt={alt} loading="lazy" decoding="async" />
  ) : (
    <div class="archive-image__placeholder" aria-hidden="true">
      <span class="archive-image__rose">✦</span>
      <span>Scan pending</span>
    </div>
  )}
  {(caption || source) && (
    <figcaption>
      {caption && <span>{caption}</span>}
      {source && <span class="archive-image__source">Source: {source}</span>}
    </figcaption>
  )}
</figure>

<style>
  .archive-image {
    margin: 0;
  }
  .archive-image img {
    display: block;
    width: 100%;
    height: auto;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--surface);
  }
  .archive-image--thumb img,
  .archive-image--cover img {
    width: 64px;
    height: 64px;
    object-fit: cover;
  }
  .archive-image--hero img {
    border-radius: 0;
    border: none;
    width: 100%;
    max-height: 420px;
    object-fit: cover;
    object-position: center 20%;
  }
  .archive-image__placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    min-height: 120px;
    padding: 1rem;
    border: 1px dashed var(--border);
    border-radius: 6px;
    color: var(--muted);
    font-size: 0.85rem;
    background: color-mix(in srgb, var(--rose) 4%, var(--surface));
  }
  .archive-image__rose {
    color: var(--rose);
    font-size: 1.25rem;
  }
  figcaption {
    margin-top: 0.4rem;
    font-size: 0.78rem;
    color: var(--muted);
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .archive-image__source {
    font-style: italic;
  }
</style>
