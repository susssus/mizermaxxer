---
import galleryPreviews from "../data/gallery_previews.json";
import ImageSourceNote from "./ImageSourceNote.astro";
import { imageAttributionForSrc } from "../lib/imageAttribution.ts";

interface Props {
  src?: string | null;
  alt: string;
  caption?: string | null;
  /** @deprecated Use automatic manifest lookup; pass sourceUrl to override. */
  source?: string | null;
  sourceUrl?: string | null;
  class?: string;
  variant?: "inline" | "hero" | "thumb" | "cover";
}

const {
  src,
  alt,
  caption,
  source,
  sourceUrl,
  class: className = "",
  variant = "inline",
} = Astro.props;

const IMAGE_EXT = /\.(jpe?g|png|webp|gif)(\?|$)/i;

function galleryPreviewKey(path: string): string {
  return path.replace(/#.*$/, "").replace(/\/$/, "");
}

function resolveSrc(path?: string | null): string | null {
  if (!path) return null;
  if (path.startsWith("http://") || path.startsWith("https://")) {
    const iaDetails = path.match(/archive\.org\/details\/([^/?#]+)/);
    if (iaDetails) {
      return `https://archive.org/download/${iaDetails[1]}/__ia_thumb.jpg`;
    }
    if (path.includes("scape.sc/pamphlets/cherdememoire")) {
      return "http://www.scape.sc/pamphlets/cherdememoire/cherdememoire00.jpg";
    }
    if (path.includes("drive.google.com/drive/folders")) {
      return null;
    }
    const preview = galleryPreviews[galleryPreviewKey(path) as keyof typeof galleryPreviews];
    if (preview) return preview;
    if (!IMAGE_EXT.test(path.split("#")[0])) {
      return null;
    }
    return path;
  }
  if (path.startsWith("images/")) return `/${path}`;
  return path.startsWith("/") ? path : `/${path}`;
}

const resolved = resolveSrc(src);
const attribution = imageAttributionForSrc(src, { sourceName: source, sourceUrl });
const showCaption = Boolean(caption || attribution);
---

<figure class={`archive-image archive-image--${variant} ${className}`.trim()}>
  {resolved ? (
    <img src={resolved} alt={alt} loading="lazy" decoding="async" />
  ) : (
    <div class="archive-image__placeholder" aria-hidden="true">
      <span class="archive-image__rose">✦</span>
      <span>Scan pending</span>
    </div>
  )}
  {showCaption && (
    <figcaption>
      {caption && <span>{caption}</span>}
      {attribution && (
        <ImageSourceNote
          src={src}
          sourceName={attribution.sourceName}
          sourceUrl={attribution.sourceUrl}
        />
      )}
    </figcaption>
  )}
</figure>

<style>
  .archive-image {
    margin: 0;
  }
  .archive-image img {
    display: block;
    width: 100%;
    height: auto;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--surface);
  }
  .archive-image--thumb img,
  .archive-image--cover img {
    width: 64px;
    height: 64px;
    object-fit: cover;
  }
  .archive-image--hero img {
    border-radius: 0;
    border: none;
    width: 100%;
    max-height: 420px;
    object-fit: cover;
    object-position: center 20%;
  }
  .archive-image__placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    min-height: 120px;
    padding: 1rem;
    border: 1px dashed var(--border);
    border-radius: 6px;
    color: var(--muted);
    font-size: 0.85rem;
    background: color-mix(in srgb, var(--rose) 4%, var(--surface));
  }
  .archive-image__rose {
    color: var(--rose);
    font-size: 1.25rem;
  }
  figcaption {
    margin-top: 0.4rem;
    font-size: 0.78rem;
    color: var(--muted);
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  figcaption :global(.image-source) {
    margin-top: 0.1rem;
  }
</style>
