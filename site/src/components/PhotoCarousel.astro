---
import ImageSourceNote from "./ImageSourceNote.astro";
import { imageAttributionForSrc } from "../lib/imageAttribution.ts";

export interface CarouselImage {
  src: string;
  caption?: string | null;
  source?: string | null;
  sourceUrl?: string | null;
}

interface Props {
  images: CarouselImage[];
  alt: string;
  id?: string;
}

const { images, alt, id = "photo-carousel" } = Astro.props;

function resolveSrc(path: string): string {
  if (path.startsWith("http://") || path.startsWith("https://")) return path;
  if (path.startsWith("images/")) return `/${path}`;
  return path.startsWith("/") ? path : `/${path}`;
}

if (images.length === 0) return null;
---

<div class="photo-carousel" data-carousel={id}>
  <div class="photo-carousel__viewport">
    <button type="button" class="photo-carousel__nav photo-carousel__nav--prev" data-carousel-prev aria-label="Previous photo">
      ‹
    </button>

    <div class="photo-carousel__track">
      {images.map((image, index) => {
        const attribution = imageAttributionForSrc(image.src, {
          sourceName: image.source,
          sourceUrl: image.sourceUrl,
        });
        return (
        <figure
          class:list={["photo-carousel__slide", { "is-active": index === 0 }]}
          data-carousel-slide
          hidden={index !== 0}
        >
          <img
            src={resolveSrc(image.src)}
            alt={image.caption ? `${alt} — ${image.caption}` : alt}
            loading={index === 0 ? "eager" : "lazy"}
            decoding="async"
          />
          {(image.caption || attribution) && (
            <figcaption>
              {image.caption && <span>{image.caption}</span>}
              {attribution && (
                <ImageSourceNote
                  src={image.src}
                  sourceName={attribution.sourceName}
                  sourceUrl={attribution.sourceUrl}
                />
              )}
            </figcaption>
          )}
        </figure>
      );
      })}
    </div>

    <button type="button" class="photo-carousel__nav photo-carousel__nav--next" data-carousel-next aria-label="Next photo">
      ›
    </button>
  </div>

  {images.length > 1 && (
    <div class="photo-carousel__footer">
      <div class="photo-carousel__dots" role="tablist" aria-label="Gallery navigation">
        {images.map((image, index) => (
          <button
            type="button"
            class:list={["photo-carousel__dot", { "is-active": index === 0 }]}
            data-carousel-dot={index}
            role="tab"
            aria-selected={index === 0 ? "true" : "false"}
            aria-label={image.caption ?? `Photo ${index + 1}`}
          />
        ))}
      </div>
      <span class="photo-carousel__counter" data-carousel-counter>1 / {images.length}</span>
    </div>
  )}

  {images.length > 1 && (
    <div class="photo-carousel__thumbs" aria-label="Photo thumbnails">
      {images.map((image, index) => (
        <button
          type="button"
          class:list={["photo-carousel__thumb", { "is-active": index === 0 }]}
          data-carousel-thumb={index}
          aria-label={image.caption ?? `Show photo ${index + 1}`}
        >
          <img src={resolveSrc(image.src)} alt="" loading="lazy" decoding="async" />
        </button>
      ))}
    </div>
  )}
</div>

<script>
  document.querySelectorAll("[data-carousel]").forEach((root) => {
    const slides = Array.from(root.querySelectorAll("[data-carousel-slide]"));
    const dots = Array.from(root.querySelectorAll("[data-carousel-dot]"));
    const thumbs = Array.from(root.querySelectorAll("[data-carousel-thumb]"));
    const counter = root.querySelector("[data-carousel-counter]");
    const prev = root.querySelector("[data-carousel-prev]");
    const next = root.querySelector("[data-carousel-next]");
    let index = 0;

    function show(nextIndex: number) {
      index = (nextIndex + slides.length) % slides.length;
      slides.forEach((slide, i) => {
        const el = slide as HTMLElement;
        el.hidden = i !== index;
        el.classList.toggle("is-active", i === index);
      });
      dots.forEach((dot, i) => {
        dot.classList.toggle("is-active", i === index);
        dot.setAttribute("aria-selected", i === index ? "true" : "false");
      });
      thumbs.forEach((thumb, i) => thumb.classList.toggle("is-active", i === index));
      if (counter) counter.textContent = `${index + 1} / ${slides.length}`;
    }

    prev?.addEventListener("click", () => show(index - 1));
    next?.addEventListener("click", () => show(index + 1));
    dots.forEach((dot, i) => dot.addEventListener("click", () => show(i)));
    thumbs.forEach((thumb, i) => thumb.addEventListener("click", () => show(i)));
  });
</script>

<style>
  .photo-carousel {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .photo-carousel__viewport {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.5rem;
  }
  .photo-carousel__track {
    position: relative;
    min-height: 220px;
  }
  .photo-carousel__slide {
    margin: 0;
  }
  .photo-carousel__slide img {
    display: block;
    width: 100%;
    max-height: 360px;
    object-fit: contain;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface);
  }
  .photo-carousel__slide figcaption {
    margin-top: 0.45rem;
    font-size: 0.78rem;
    color: var(--muted);
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .photo-carousel__nav {
    width: 2rem;
    height: 2rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--surface);
    color: var(--accent);
    font-size: 1.25rem;
    line-height: 1;
    cursor: pointer;
  }
  .photo-carousel__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }
  .photo-carousel__dots {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .photo-carousel__dot {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: transparent;
    padding: 0;
    cursor: pointer;
  }
  .photo-carousel__dot.is-active {
    background: var(--rose);
    border-color: var(--rose);
  }
  .photo-carousel__counter {
    font-size: 0.78rem;
    color: var(--muted);
    white-space: nowrap;
  }
  .photo-carousel__thumbs {
    display: flex;
    gap: 0.4rem;
    overflow-x: auto;
    padding-bottom: 0.15rem;
  }
  .photo-carousel__thumb {
    flex: 0 0 auto;
    width: 3.25rem;
    height: 3.25rem;
    padding: 0;
    border: 2px solid transparent;
    border-radius: 6px;
    overflow: hidden;
    cursor: pointer;
    background: transparent;
  }
  .photo-carousel__thumb.is-active {
    border-color: var(--rose);
  }
  .photo-carousel__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
</style>
