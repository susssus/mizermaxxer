---
import {
  MM_BAND_YEARS,
  MEMBER_CAREER_ORDER,
  boundsForMemberships,
  formatActiveRange,
  layoutMembershipBars,
  memberDisplayName,
  membershipsForPerson,
  phaseLabel,
  type CareerPhase,
} from "../lib/careerTimeline";

const trackWidth = 680;
const labelWidth = 88;
const laneHeight = 22;
const laneGap = 4;
const rowGap = 10;
const topPad = 28;
const bottomPad = 24;

const prepared = MEMBER_CAREER_ORDER.map((personId) => {
  const memberships = membershipsForPerson(personId);
  return {
    personId,
    name: memberDisplayName(personId),
    memberships,
    slug: personId.replace(/^person_/, ""),
  };
}).filter((row) => row.memberships.length > 0);

const allMemberships = prepared.flatMap((row) => row.memberships);
const bounds = boundsForMemberships(allMemberships, 1);

const rows = prepared.map((row) => {
  const { bars, laneCount } = layoutMembershipBars(row.memberships, bounds, trackWidth);
  const bodyHeight = laneCount * (laneHeight + laneGap) - laneGap;
  return { ...row, bars, laneCount, bodyHeight: Math.max(bodyHeight, laneHeight) };
});

let yCursor = topPad;
const positioned = rows.map((row) => {
  const y = yCursor;
  yCursor += row.bodyHeight + rowGap;
  return { ...row, y };
});

const height = yCursor + bottomPad;
const span = bounds.maxYear - bounds.minYear || 1;
const mmX = labelWidth + ((MM_BAND_YEARS.start - bounds.minYear) / span) * trackWidth;
const mmW = Math.max(((MM_BAND_YEARS.end - MM_BAND_YEARS.start) / span) * trackWidth, 2);

const tickYears: number[] = [];
for (let y = bounds.minYear; y <= bounds.maxYear; y += 1) {
  if (y % 5 === 0 || y === bounds.minYear || y === bounds.maxYear) tickYears.push(y);
}

const phaseClass: Record<CareerPhase, string> = {
  before: "career-bar--before",
  during: "career-bar--during",
  after: "career-bar--after",
};
---

<section class="card career-overview">
  <div class="career-overview__scroll">
    <svg
      class="career-overview__svg"
      viewBox={`0 0 ${labelWidth + trackWidth} ${height}`}
      role="img"
      aria-label="Career comparison timeline for all Malice Mizer members"
    >
      <rect
        class="career-timeline__mm-zone"
        x={mmX}
        y={topPad - 6}
        width={mmW}
        height={yCursor - topPad}
        rx="4"
      />
      <text class="career-timeline__mm-label" x={mmX + mmW / 2} y={16} text-anchor="middle">
        Malice Mizer
      </text>

      {tickYears.map((year) => {
        const x = labelWidth + ((year - bounds.minYear) / span) * trackWidth;
        return (
          <g>
            <line
              class="career-timeline__tick"
              x1={x}
              y1={topPad - 2}
              x2={x}
              y2={height - bottomPad + 2}
            />
            <text class="career-timeline__tick-label" x={x} y={height - 6} text-anchor="middle">
              {year}
            </text>
          </g>
        );
      })}

      {positioned.map((row) => (
        <g>
          <a href={`/members/${row.slug}`}>
            <text
              class="career-overview__name"
              x={0}
              y={row.y + row.bodyHeight / 2 + 4}
            >
              {row.name}
            </text>
          </a>
          {row.bars.map((bar) => {
            const x = labelWidth + bar.x;
            const y = row.y + bar.lane * (laneHeight + laneGap);
            const short =
              bar.orgName.length > 14 && bar.width < 90
                ? `${bar.orgName.slice(0, 12)}…`
                : bar.orgName.length > 18
                  ? `${bar.orgName.slice(0, 16)}…`
                  : bar.orgName;
            return (
              <g
                class={`career-bar ${phaseClass[bar.phase]} ${bar.isMotherBand ? "career-bar--mother" : ""}`}
              >
                <a href={`/entity/${bar.orgId}`}>
                  <title>{`${row.name} · ${bar.orgName} · ${formatActiveRange(bar.active, bar.openEnded)} · ${phaseLabel(bar.phase)}`}</title>
                  <rect x={x} y={y} width={bar.width} height={laneHeight} rx="4" />
                  {bar.width > 36 && (
                    <text
                      x={x + 6}
                      y={y + laneHeight / 2 + 4}
                      class="career-bar__label"
                    >
                      {short}
                    </text>
                  )}
                </a>
              </g>
            );
          })}
        </g>
      ))}
    </svg>
  </div>

  <div class="career-overview__legend">
    <span class="career-legend career-legend--before">Before</span>
    <span class="career-legend career-legend--during">During / concurrent</span>
    <span class="career-legend career-legend--after">After</span>
    <span class="career-legend career-legend--mother">Malice Mizer</span>
  </div>

  <ul class="career-overview__list">
    {prepared.map((row) => (
      <li>
        <strong><a href={`/members/${row.slug}`}>{row.name}</a></strong>
        <ul>
          {row.memberships.map((m) => (
            <li>
              <a href={`/entity/${m.orgId}`}>{m.orgName}</a>
              <span class="muted">
                {" "}
                · {formatActiveRange(m.active, m.openEnded)} · {phaseLabel(m.phase)}
              </span>
            </li>
          ))}
        </ul>
      </li>
    ))}
  </ul>
</section>

<style>
  .career-overview__scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin: 0 -0.25rem 0.85rem;
    padding: 0 0.25rem;
  }
  .career-overview__svg {
    display: block;
    width: 100%;
    min-width: 640px;
    height: auto;
  }
  .career-timeline__mm-zone {
    fill: color-mix(in srgb, var(--rose) 14%, transparent);
    stroke: color-mix(in srgb, var(--rose) 35%, var(--border));
    stroke-width: 1;
  }
  .career-timeline__mm-label {
    fill: var(--rose);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .career-timeline__tick {
    stroke: var(--border);
    stroke-width: 1;
    stroke-dasharray: 2 3;
  }
  .career-timeline__tick-label {
    fill: var(--muted);
    font-size: 10px;
  }
  .career-overview__name {
    fill: var(--accent);
    font-size: 12px;
    font-weight: 600;
  }
  .career-bar rect {
    stroke: color-mix(in srgb, #1a1410 35%, transparent);
    stroke-width: 1;
  }
  .career-bar--before rect {
    fill: #6b635c;
  }
  .career-bar--during rect {
    fill: #9a3d55;
  }
  .career-bar--after rect {
    fill: #2f7a6c;
  }
  .career-bar--mother rect {
    fill: #b44560;
    stroke: #f0c4ce;
    stroke-width: 1.5;
  }
  .career-bar__label {
    fill: #fff8f2;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.01em;
    pointer-events: none;
    paint-order: stroke fill;
    stroke: rgba(18, 14, 12, 0.55);
    stroke-width: 2.5px;
  }
  .career-overview__legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem 1.1rem;
    font-size: 0.78rem;
    color: var(--muted);
    margin-bottom: 1rem;
  }
  .career-legend::before {
    content: "";
    display: inline-block;
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 3px;
    margin-right: 0.35rem;
    vertical-align: -1px;
    border: 1px solid var(--border);
  }
  .career-legend--before::before {
    background: #6b635c;
  }
  .career-legend--during::before {
    background: #9a3d55;
  }
  .career-legend--after::before {
    background: #2f7a6c;
  }
  .career-legend--mother::before {
    background: #b44560;
    border-color: #f0c4ce;
  }
  .career-overview__list {
    margin: 0;
    padding: 0.85rem 0 0;
    border-top: 1px solid var(--border);
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    font-size: 0.86rem;
  }
  .career-overview__list > li > ul {
    margin: 0.25rem 0 0;
    padding-left: 1rem;
  }
  .career-overview__list a {
    color: var(--accent);
  }
</style>
