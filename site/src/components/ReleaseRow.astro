---
import ImageSourceNote from "./ImageSourceNote.astro";

interface Album {
  id: string;
  title_en: string;
  title_ja: string;
  type: string;
  release_date: string;
  label?: string | null;
  cover_image?: string | null;
  verification_status: string;
  tracks: unknown[];
}

interface Props {
  album: Album;
}

const { album } = Astro.props;

function coverSrc(path?: string | null) {
  if (!path) return null;
  return path.startsWith("/") ? path : `/${path}`;
}
---

<tr>
  <td class="cover-cell">
    {album.cover_image ? (
      <figure class="cover-thumb-wrap">
        <img class="cover-thumb" src={coverSrc(album.cover_image)!} alt="" loading="lazy" />
        <ImageSourceNote src={album.cover_image} compact />
      </figure>
    ) : (
      "—"
    )}
  </td>
  <td>{album.release_date}</td>
  <td><span class={`badge ${album.verification_status}`}>{album.verification_status.replaceAll("_", " ")}</span></td>
  <td>
    <a href={`/discography/${album.id}`}>{album.title_en}</a>
    <br /><span class="muted">{album.title_ja}</span>
  </td>
  <td>{album.type.replaceAll("_", " ")}</td>
  <td>{album.label ?? "—"}</td>
  <td>{album.tracks.length || "—"}</td>
</tr>

<style>
  .cover-cell {
    vertical-align: top;
    min-width: 5.5rem;
  }
  .cover-thumb-wrap {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .cover-thumb {
    width: 64px;
    height: 64px;
    object-fit: cover;
    border-radius: 4px;
    border: 1px solid var(--border);
  }
</style>
